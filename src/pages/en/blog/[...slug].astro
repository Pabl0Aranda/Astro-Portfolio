---
import { getCollection } from "astro:content";
import Layout from "../../../layouts/Layout.astro";
import { getLangFromUrl } from "../../../i18n/ui";

// Generamos las rutas dinámicas para cada post
export async function getStaticPaths() {
  const blogEntries = await getCollection("blog");
  return blogEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, remarkPluginFrontmatter } = await entry.render();

// Obtener el idioma de la URL
const lang = getLangFromUrl(Astro.url);
---

<Layout
  title={`${entry.data.title} | Pablo.`}
  description={entry.data.description}
>
  <div
    class="mx-auto w-full max-w-3xl px-6 py-20 text-neutral-900 md:px-0 md:py-32 dark:text-white"
  >
    <a
      href={lang === "es" ? "/blog" : "/en/blog"}
      class="text-albero mb-10 inline-flex items-center font-medium transition-colors duration-300 hover:text-neutral-900 dark:hover:text-white"
    >
      <svg
        class="mr-2 h-4 w-4"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
      </svg>
      {lang === "es" ? "Volver al blog" : "Back to blog"}
    </a>

    <header class="mb-14">
      <div class="mb-6 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <span
            class="text-albero rounded-full bg-neutral-100 px-3 py-1 text-xs font-bold dark:bg-white/10"
          >
            {entry.data.category}
          </span>
          <time class="text-sm text-neutral-500">
            {
              entry.data.date.toLocaleDateString(
                lang === "es" ? "es-ES" : "en-US",
                {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                },
              )
            }
          </time>
          <span class="hidden text-neutral-300 md:inline dark:text-neutral-600"
            >•</span
          >
          <span class="text-sm text-neutral-500">
            {remarkPluginFrontmatter.minutesRead}
            {lang === "es" ? "min de lectura" : "min read"}
          </span>
        </div>

        <button
          id="btn-download-paper"
          class="hover:bg-albero dark:hover:bg-albero group flex items-center justify-center rounded-full bg-neutral-100 p-2.5 text-neutral-600 transition-colors duration-300 hover:text-black dark:bg-white/10 dark:text-neutral-300 dark:hover:text-black print:hidden"
          title={lang === "es"
            ? "Descargar como Paper (PDF)"
            : "Download as Paper (PDF)"}
        >
          <svg
            class="h-5 w-5 transition-transform duration-300 group-hover:-translate-y-0.5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
            ></path>
          </svg>
        </button>
      </div>

      <h1
        class="mb-6 text-3xl leading-tight font-bold tracking-tight text-neutral-900 md:text-5xl dark:text-white"
      >
        {entry.data.title}
      </h1>
    </header>

    <article class="prose-custom w-full max-w-full break-words">
      <Content />
    </article>
  </div>
</Layout>

<script>
  // Usamos astro:page-load para que funcione bien con las View Transitions de Astro
  document.addEventListener("astro:page-load", () => {
    const btn = document.getElementById("btn-download-paper");
    if (btn) {
      btn.addEventListener("click", () => {
        window.print();
      });
    }
  });
</script>

<style is:global>
  @reference "../../../styles/global.css";

  .prose-custom {
    @apply space-y-6 text-base leading-relaxed text-neutral-700 dark:text-neutral-300;
  }
  @media (min-width: 768px) {
    .prose-custom {
      @apply text-lg;
    }
  }

  .prose-custom h2 {
    @apply mt-12 mb-6 text-2xl font-bold break-words text-neutral-900 dark:text-white;
  }
  @media (min-width: 768px) {
    .prose-custom h2 {
      @apply text-3xl;
    }
  }

  .prose-custom h3 {
    @apply mt-8 mb-4 text-xl font-bold break-words text-neutral-900 dark:text-white;
  }
  @media (min-width: 768px) {
    .prose-custom h3 {
      @apply text-2xl;
    }
  }

  /* Párrafos y listas adaptados al modo claro/oscuro */
  .prose-custom p {
    @apply mb-6 text-neutral-700 dark:text-neutral-400;
  }
  .prose-custom ul {
    @apply mb-6 list-inside list-disc space-y-2 text-neutral-700 dark:text-neutral-400;
  }
  .prose-custom ol {
    @apply mb-6 list-inside list-decimal space-y-2 text-neutral-700 dark:text-neutral-400;
  }

  /* Enlaces */
  .prose-custom a {
    @apply text-albero break-words underline decoration-neutral-300 underline-offset-4 transition-colors dark:decoration-white/30;
  }
  .prose-custom a:hover {
    @apply decoration-albero;
  }

  /* Citas (Blockquotes) */
  .prose-custom blockquote {
    @apply border-albero my-8 rounded-r-lg border-l-4 bg-neutral-50 py-2 pr-4 pl-4 text-neutral-600 italic dark:bg-white/5 dark:text-neutral-400;
  }

  /* Bloques de código general (Fondo oscuro siempre, queda mejor para el código) */
  .prose-custom pre {
    @apply my-8 max-w-full overflow-x-auto rounded-xl border border-neutral-200 bg-[#1a1a1a] p-4 text-sm text-neutral-300 dark:border-white/10;
  }

  /* Código en línea (inline code) */
  .prose-custom code {
    @apply text-albero rounded bg-neutral-200 px-1.5 py-0.5 text-sm break-words dark:bg-white/10;
  }
  .prose-custom pre code {
    @apply rounded-none bg-transparent p-0 break-normal text-inherit;
  }

  /* Imágenes */
  .prose-custom img {
    @apply mx-auto my-8 h-auto max-w-full rounded-xl border border-neutral-200 shadow-sm dark:border-white/10 dark:shadow-none;
  }

  /* Tablas adaptadas */
  .prose-custom table {
    @apply mb-8 block w-full max-w-full border-collapse overflow-x-auto text-sm text-neutral-700 dark:text-neutral-400;
  }
  @media (min-width: 768px) {
    .prose-custom table {
      @apply text-base;
    }
  }

  .prose-custom th,
  .prose-custom td {
    @apply min-w-[120px] border border-neutral-300 p-3 text-left dark:border-white/20;
  }
  .prose-custom th {
    @apply bg-neutral-100 font-bold text-neutral-900 dark:bg-white/5 dark:text-white;
  }

  /* =========================================
     ESTILOS DE IMPRESIÓN (FORMATO PAPER PDF)
     ========================================= */
  @media print {
    /* 1. Ocultar todo lo que no sea el artículo (navbar, footer, botón de volver, etc) */
    nav,
    footer,
    #btn-download-paper,
    a[href^="/blog"],
    a[href^="/en/blog"] {
      display: none !important;
    }

    /* 2. Forzar colores de papel (fondo blanco, texto negro) ignorando el dark mode */
    body,
    html,
    .prose-custom {
      background-color: white !important;
      color: black !important;
    }

    /* 3. Tipografía académica para el texto */
    .prose-custom,
    .prose-custom p,
    .prose-custom li {
      font-family: "Times New Roman", Times, serif !important;
      font-size: 12pt !important;
      line-height: 1.5 !important;
      text-align: justify !important;
    }

    /* 4. Títulos estilo académico */
    h1 {
      font-family: "Times New Roman", Times, serif !important;
      font-size: 24pt !important;
      text-align: center !important;
      margin-bottom: 24px !important;
      color: black !important;
    }
    .prose-custom h2 {
      font-family: "Times New Roman", Times, serif !important;
      font-size: 16pt !important;
      border-bottom: 1px solid black;
      padding-bottom: 4px;
      margin-top: 24px !important;
      color: black !important;
    }

    /* 5. Ajustar bloques de código para impresión */
    .prose-custom pre {
      background-color: #f5f5f5 !important;
      color: black !important;
      border: 1px solid #ccc !important;
      white-space: pre-wrap !important; /* Para que el código no se corte por la derecha */
      page-break-inside: avoid !important; /* Evita que un bloque de código se parta a la mitad de dos páginas */
    }

    /* 6. Enlaces legibles en papel */
    .prose-custom a {
      color: black !important;
      text-decoration: underline !important;
    }

    /* 7. Evitar saltos de página feos en imágenes o tablas */
    img,
    table,
    blockquote {
      page-break-inside: avoid !important;
    }
  }
</style>
