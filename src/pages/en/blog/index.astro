---
import Layout from "../../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { getLangFromUrl } from "../../../i18n/ui";

const lang = getLangFromUrl(Astro.url);

const allPosts = await getCollection("blog", ({ data }) => {
  return data.draft !== true;
});
const sortedPosts = allPosts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const categories = [...new Set(sortedPosts.map((post) => post.data.category))];
---

<Layout
  title={lang === "es" ? "Blog | Pablo." : "Blog | Pablo."}
  description={lang === "es"
    ? "Artículos sobre desarrollo e ingeniería."
    : "Articles about development and engineering."}
>
  <section class="py-20 md:py-32 reveal-text">
    <header class="mb-16">
      <h1
        class="text-4xl md:text-6xl font-bold tracking-tight mb-6 text-neutral-900 dark:text-white"
      >
        {lang === "es" ? "Mi " : "My "}<span class="text-albero">Blog</span>.
      </h1>
      <p class="text-lg text-neutral-600 dark:text-neutral-400 max-w-2xl">
        {
          lang === "es"
            ? "Escribo sobre código, diseño y opiniones."
            : "I write about code, design, and opinions."
        }
      </p>
    </header>

    <div class="flex flex-wrap gap-3 mb-12">
      <button
        class="filter-btn active px-5 py-2 rounded-full text-sm transition-all duration-300 hover:scale-105 bg-albero text-black border border-albero font-semibold hover:bg-neutral-900 hover:text-white dark:hover:bg-white dark:hover:text-black"
        data-filter="all"
      >
        {lang === "es" ? "Todos" : "All"}
      </button>

      {
        categories.map((category) => (
          <button
            class="filter-btn px-5 py-2 rounded-full text-sm transition-all duration-300 hover:scale-105 bg-transparent text-neutral-600 dark:text-white border border-neutral-300 dark:border-white/20 font-medium hover:border-albero hover:text-albero dark:hover:border-albero dark:hover:text-albero"
            data-filter={category}
          >
            {category}
          </button>
        ))
      }
    </div>

    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8"
      id="posts-grid"
    >
      {
        sortedPosts.map((post) => (
          <article
            class="post-card group border border-neutral-200 dark:border-white/10 rounded-2xl p-6 bg-neutral-50 dark:bg-white/5 hover:border-albero/50 hover:bg-neutral-100 dark:hover:bg-white/10 transition-all duration-300 flex flex-col h-full"
            data-category={post.data.category}
          >
            <div class="mb-4 flex justify-between items-center">
              <span class="text-xs font-bold px-3 py-1 bg-black/5 dark:bg-white/10 text-albero rounded-full">
                {post.data.category}
              </span>
              <time class="text-sm text-neutral-500">
                {post.data.date.toLocaleDateString(
                  lang === "es" ? "es-ES" : "en-US",
                  {
                    year: "numeric",
                    month: "short",
                    day: "numeric",
                  },
                )}
              </time>
            </div>

            <h2 class="text-xl font-bold mb-3 transition-colors duration-300 text-neutral-900 dark:text-white">
              <a
                href={
                  lang === "es" ? `/blog/${post.slug}` : `/en/blog/${post.slug}`
                }
                class="hover:text-albero dark:hover:text-albero focus:outline-none transition-colors duration-300"
              >
                {post.data.title}
              </a>
            </h2>

            <p class="text-neutral-600 dark:text-neutral-400 text-sm leading-relaxed mb-6 grow">
              {post.data.description}
            </p>

            <a
              href={
                lang === "es" ? `/blog/${post.slug}` : `/en/blog/${post.slug}`
              }
              class="mt-auto flex items-center text-sm font-medium text-neutral-900 dark:text-white hover:text-albero dark:hover:text-albero transition-colors duration-300 w-fit"
            >
              {lang === "es" ? "Leer artículo" : "Read article"}
              <svg
                class="w-4 h-4 ml-2 group-hover:translate-x-2 transition-transform duration-300"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M14 5l7 7m0 0l-7 7m7-7H3"
                />
              </svg>
            </a>
          </article>
        ))
      }
    </div>
  </section>
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const filterBtns = document.querySelectorAll(".filter-btn");
    const postCards = document.querySelectorAll(".post-card");

    const activeClasses = [
      "bg-albero",
      "text-black",
      "border-albero",
      "font-semibold",
      "active",
      "hover:bg-neutral-900",
      "hover:text-white",
      "dark:hover:bg-white",
      "dark:hover:text-black",
    ];

    const inactiveClasses = [
      "bg-transparent",
      "text-neutral-600",
      "dark:text-white",
      "border-neutral-300",
      "dark:border-white/20",
      "font-medium",
      "hover:border-albero",
      "hover:text-albero",
      "dark:hover:border-albero",
      "dark:hover:text-albero",
    ];

    filterBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        filterBtns.forEach((b) => {
          b.classList.remove(...activeClasses);
          b.classList.add(...inactiveClasses);
        });

        btn.classList.remove(...inactiveClasses);
        btn.classList.add(...activeClasses);

        const filterValue = btn.getAttribute("data-filter");

        postCards.forEach((card) => {
          const postCategory = card.getAttribute("data-category");

          if (filterValue === "all" || filterValue === postCategory) {
            (card as HTMLElement).style.display = "flex";
            (card as HTMLElement).style.animation =
              "fadeIn 0.5s ease-out forwards";
          } else {
            (card as HTMLElement).style.display = "none";
          }
        });
      });
    });
  });
</script>

<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
