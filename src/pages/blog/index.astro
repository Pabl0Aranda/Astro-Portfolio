---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog", ({ data }) => {
  return data.draft !== true;
});
const sortedPosts = allPosts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const categories = [...new Set(sortedPosts.map((post) => post.data.category))];
const categoryCounts = sortedPosts.reduce(
  (acc, post) => {
    acc[post.data.category] = (acc[post.data.category] || 0) + 1;
    return acc;
  },
  {} as Record<string, number>,
);

const getCategoryIcon = (category: string) => {
  switch (category) {
    case "Desarrollo Web":
      return '<svg class="w-4 h-4 mr-1.5 inline-block" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" /></svg>';
    case "Inteligencia Artificial":
      return '<svg class="w-4 h-4 mr-1.5 inline-block" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" /></svg>';
    case "Arquitectura":
      return '<svg class="w-4 h-4 mr-1.5 inline-block" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>';
    case 'Software': return '<svg class="w-4 h-4 mr-1.5 inline-block" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>';
    case 'Algoritmos': return '<svg class="w-4 h-4 mr-1.5 inline-block" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4" /></svg>';
    case 'Sistemas Operativos': return '<svg class="w-4 h-4 mr-1.5 inline-block" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>';
    default: return '<svg class="w-4 h-4 mr-1.5 inline-block" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" /></svg>';
  }
};

const getRelativeDate = (date: Date) => {
  const rtf = new Intl.RelativeTimeFormat("es", { numeric: "auto" });
  const daysDifference = Math.round(
    (date.getTime() - new Date().getTime()) / (1000 * 60 * 60 * 24),
  );
  if (Math.abs(daysDifference) > 30) {
    return date.toLocaleDateString("es-ES", {
      year: "numeric",
      month: "short",
      day: "numeric",
    });
  }
  return rtf.format(daysDifference, "day");
};
---

<Layout
  title="Blog | Pablo."
  description="Artículos sobre desarrollo e ingeniería."
>
  <section class="reveal-text py-20 md:py-32">
    <header class="mb-16">
      <h1
        class="mb-6 text-4xl font-bold tracking-tight text-neutral-900 md:text-6xl dark:text-white"
      >
        Mi <span class="text-albero">Blog</span>.
      </h1>
      <p class="max-w-2xl text-lg text-neutral-600 dark:text-neutral-400">
        Escribo sobre código, diseño y opiniones.
      </p>
    </header>

    <div class="mb-12 flex flex-wrap items-center justify-between gap-6">
      <div class="flex flex-wrap gap-3">
        <button
          class="filter-btn active bg-albero border-albero rounded-full border px-5 py-2 text-sm font-semibold text-black transition-all duration-300 hover:scale-105 hover:bg-neutral-900 hover:text-white dark:hover:bg-white dark:hover:text-black flex items-center justify-center"
          data-filter="all"
        >
          Todos
        </button>

        {
          categories.map((category) => (
            <button
              class="filter-btn hover:border-albero hover:text-albero dark:hover:border-albero dark:hover:text-albero rounded-full border border-neutral-300 bg-transparent px-5 py-2 text-sm font-medium text-neutral-600 transition-all duration-300 hover:scale-105 dark:border-white/20 dark:text-white flex items-center justify-center"
              data-filter={category}
            >
              <Fragment set:html={getCategoryIcon(category)} />
              {category} <span class="ml-1.5 opacity-60">({categoryCounts[category]})</span>
            </button>
          ))
        }
      </div>

      <div
        class="flex items-center gap-1 rounded-full border border-neutral-200 p-1 dark:border-white/10"
      >
        <button
          id="btn-view-grid"
          class="rounded-full bg-neutral-200 p-2 text-black transition-colors dark:bg-white/20 dark:text-white"
          title="Vista de cuadrícula"
        >
          <svg
            class="h-5 w-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"
            ></path>
          </svg>
        </button>
        <button
          id="btn-view-list"
          class="rounded-full p-2 text-neutral-500 transition-colors hover:bg-neutral-100 hover:text-black dark:text-neutral-400 dark:hover:bg-white/10 dark:hover:text-white"
          title="Vista de lista"
        >
          <svg
            class="h-5 w-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </div>

    <div
      class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3"
      id="posts-grid"
    >
      {
        sortedPosts.map((post) => (
          <article
            class="tilt-card post-card group flex h-full min-h-[220px] flex-col rounded-2xl border border-neutral-200 bg-neutral-50 p-6 transition-all duration-500 hover:bg-neutral-100 hover:shadow-xl dark:border-white/10 dark:bg-white/5 dark:hover:bg-[#151515] hover:-translate-y-1 dark:hover:border-albero/30"
            data-category={post.data.category}
            style={`view-transition-name: post-${post.slug.replace(/[^a-zA-Z0-9]/g, '-')};`}
          >
            <div class="mb-4 flex items-center justify-between">
              <span class="text-albero rounded-full bg-black/5 px-3 py-1 text-xs font-bold dark:bg-white/10">
                {post.data.category}
              </span>
              <time class="text-sm text-neutral-500 capitalize">
                {getRelativeDate(post.data.date)}
              </time>
            </div>

            <h2 class="mb-1 text-xl font-bold text-neutral-900 transition-colors duration-300 dark:text-white">
              <a
                href={`/blog/${post.slug}`}
                class="hover:text-albero dark:hover:text-albero transition-colors duration-300 focus:outline-none"
              >
                {post.data.title}
              </a>
            </h2>

            <div class="grid grid-rows-[0fr] opacity-0 transition-all duration-500 ease-in-out group-hover:mt-3 group-hover:grid-rows-[1fr] group-hover:opacity-100">
              <div class="overflow-hidden">
                <p class="line-clamp-2 text-sm leading-relaxed text-neutral-600 dark:text-neutral-400">
                  {post.data.description}
                </p>
              </div>
            </div>

            <a
              href={`/blog/${post.slug}`}
              class="hover:text-albero dark:hover:text-albero mt-auto flex w-fit items-center text-sm font-medium text-neutral-900 transition-colors duration-300 dark:text-white"
            >
              Leer artículo
              <svg
                class="ml-2 h-4 w-4 transition-transform duration-300 group-hover:translate-x-2"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M14 5l7 7m0 0l-7 7m7-7H3"
                />
              </svg>
            </a>
          </article>
        ))
      }
    </div>

    <div class="mt-12 flex justify-center">
      <button
        id="btn-load-more"
        class="group hover:bg-albero dark:hover:bg-albero flex items-center justify-center rounded-full bg-neutral-900 px-6 py-3 text-sm font-semibold text-white transition-all duration-300 hover:scale-105 hover:text-black dark:bg-white dark:text-black"
        style="display: none;"
      >
        Cargar más artículos
        <svg
          class="ml-2 h-4 w-4 transition-transform duration-300 group-hover:translate-y-1"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M19 9l-7 7-7-7"></path>
        </svg>
      </button>
    </div>
  </section>
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const filterBtns = document.querySelectorAll(".filter-btn");
    const postCards = document.querySelectorAll(".post-card");

    // Arrays separados palabra por palabra para que JavaScript no se rompa
    const activeClasses = [
      "bg-albero",
      "text-black",
      "border-albero",
      "font-semibold",
      "active",
      "hover:bg-neutral-900",
      "hover:text-white",
      "dark:hover:bg-white",
      "dark:hover:text-black",
    ];

    const inactiveClasses = [
      "bg-transparent",
      "text-neutral-600",
      "dark:text-white",
      "border-neutral-300",
      "dark:border-white/20",
      "font-medium",
      "hover:border-albero",
      "hover:text-albero",
      "dark:hover:border-albero",
      "dark:hover:text-albero",
    ];

    let activeFilters = new Set();
    let currentVisibleCount = 9;
    const btnLoadMore = document.getElementById("btn-load-more");

    const updateDOM = () => {
      let visibleCount = 0;
      let matchedCount = 0;
      
      postCards.forEach((card) => {
        const postCategory = card.getAttribute("data-category") || "";
        const matchFilter = activeFilters.size === 0 || activeFilters.has(postCategory);
        
        if (matchFilter) {
          matchedCount++;
          if (visibleCount < currentVisibleCount) {
            (card as HTMLElement).style.display = "flex";
            // Remove fadeIn animation so it doesn't conflict with View Transitions
            (card as HTMLElement).style.animation = "none";
            visibleCount++;
          } else {
            (card as HTMLElement).style.display = "none";
          }
        } else {
          (card as HTMLElement).style.display = "none";
        }
      });
      
      if (btnLoadMore) {
        if (matchedCount > currentVisibleCount) {
          btnLoadMore.style.display = "flex";
        } else {
          btnLoadMore.style.display = "none";
        }
      }
    };

    const updateVisibility = () => {
      // Use View Transitions API if supported
      if ((document as any).startViewTransition) {
        (document as any).startViewTransition(() => updateDOM());
      } else {
        updateDOM();
      }
    };

    // Inicializar vista
    updateVisibility();

    if (btnLoadMore) {
      btnLoadMore.addEventListener("click", () => {
        currentVisibleCount += 6;
        updateVisibility();
      });
    }

    const btnAll = Array.from(filterBtns).find(b => b.getAttribute("data-filter") === "all");

    filterBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const filter = btn.getAttribute("data-filter") || "all";

        if (filter === "all") {
          activeFilters.clear();
          filterBtns.forEach((b) => {
            b.classList.remove(...activeClasses);
            b.classList.add(...inactiveClasses);
          });
          btn.classList.remove(...inactiveClasses);
          btn.classList.add(...activeClasses);
        } else {
          if (activeFilters.has(filter)) {
            activeFilters.delete(filter);
            btn.classList.remove(...activeClasses);
            btn.classList.add(...inactiveClasses);
          } else {
            activeFilters.add(filter);
            btn.classList.remove(...inactiveClasses);
            btn.classList.add(...activeClasses);
          }
          
          if (activeFilters.size === 0) {
            btnAll?.classList.remove(...inactiveClasses);
            btnAll?.classList.add(...activeClasses);
          } else {
            btnAll?.classList.remove(...activeClasses);
            btnAll?.classList.add(...inactiveClasses);
          }
        }

        currentVisibleCount = 9; // Reset contador
        updateVisibility();
      });
    });

    // Toggle Vista Cuadrícula / Lista
    const btnViewGrid = document.getElementById("btn-view-grid");
    const btnViewList = document.getElementById("btn-view-list");
    const postsGrid = document.getElementById("posts-grid");

    if (btnViewGrid && btnViewList && postsGrid) {
      const gridClasses = [
        "grid",
        "grid-cols-1",
        "gap-8",
        "md:grid-cols-2",
        "lg:grid-cols-3",
      ];
      const listClasses = ["flex", "flex-col", "gap-4"];

      const activeBtnClasses = [
        "bg-neutral-200",
        "text-black",
        "dark:bg-white/20",
        "dark:text-white",
      ];
      const inactiveBtnClasses = [
        "text-neutral-500",
        "dark:text-neutral-400",
        "hover:bg-neutral-100",
        "hover:text-black",
        "dark:hover:bg-white/10",
        "dark:hover:text-white",
      ];

      btnViewGrid.addEventListener("click", () => {
        postsGrid.classList.remove(...listClasses, "view-list");
        postsGrid.classList.add(...gridClasses, "view-grid");

        btnViewGrid.classList.remove(...inactiveBtnClasses);
        btnViewGrid.classList.add(...activeBtnClasses);

        btnViewList.classList.remove(...activeBtnClasses);
        btnViewList.classList.add(...inactiveBtnClasses);
      });

      btnViewList.addEventListener("click", () => {
        postsGrid.classList.remove(...gridClasses, "view-grid");
        postsGrid.classList.add(...listClasses, "view-list");

        btnViewList.classList.remove(...inactiveBtnClasses);
        btnViewList.classList.add(...activeBtnClasses);

        btnViewGrid.classList.remove(...activeBtnClasses);
        btnViewGrid.classList.add(...inactiveBtnClasses);
      });
    }
  });
</script>

<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Estilos para la vista de lista (List View) */
  @media (min-width: 768px) {
    :global(.view-list .post-card) {
      flex-direction: row !important;
      align-items: center !important;
      justify-content: space-between !important;
      gap: 2rem !important;
      padding: 1.5rem 2rem !important;
      min-height: auto !important;
    }
    :global(.view-list .post-card > div:first-child) {
      margin-bottom: 0 !important;
      width: 25% !important;
      flex-shrink: 0 !important;
      flex-direction: column !important;
      align-items: flex-start !important;
      gap: 0.5rem !important;
    }
    :global(.view-list .post-card > h2) {
      margin-bottom: 0 !important;
      flex: 1 !important;
    }
    :global(.view-list .post-card > div.grid) {
      display: none !important;
    }
    :global(.view-list .post-card > a:last-child) {
      margin-top: 0 !important;
      width: max-content !important;
      flex-shrink: 0 !important;
    }
  }
</style>
