---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

// Obtenemos los posts que no sean borradores (draft: false) y los ordenamos por fecha
const posts = await getCollection("blog", ({ data }) => {
  return data.draft !== true;
});
const postsOrdenados = posts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---
<Layout
  title="Blog | Pablo Aranda"
  description="Artículos sobre desarrollo e ingeniería."
>
  <section class="py-32">
    <h1 class="text-5xl font-bold tracking-tight mb-4">
      Blog<span class="text-albero">.</span>
    </h1>
    <p class="text-xl text-neutral-400 mb-12">
      Escribo sobre código, diseño y opiniones.
    </p>

    <div class="space-y-8">
      {
        postsOrdenados.map((post) => (
          <article class="group border-b border-white/10 pb-8">
            <p class="text-sm text-neutral-500 mb-2">
              {post.data.date.toLocaleDateString("es-ES", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })}
            </p>
            <a href={`/blog/${post.slug}`}>
              <h2 class="text-2xl font-semibold mb-3 group-hover:text-albero transition-colors duration-300">
                {post.data.title}
              </h2>
            </a>
            <p class="text-neutral-400">{post.data.description}</p>
          </article>
        ))
      }
    </div>
  </section>
</Layout>
