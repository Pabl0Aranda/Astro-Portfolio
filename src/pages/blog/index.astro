---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog", ({ data }) => {
  return data.draft !== true;
});
const sortedPosts = allPosts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const categories = [...new Set(sortedPosts.map((post) => post.data.category))];

const getRelativeDate = (date: Date) => {
  const rtf = new Intl.RelativeTimeFormat('es', { numeric: 'auto' });
  const daysDifference = Math.round(
    (date.getTime() - new Date().getTime()) / (1000 * 60 * 60 * 24)
  );
  if (Math.abs(daysDifference) > 30) {
    return date.toLocaleDateString('es-ES', {
      year: 'numeric', month: 'short', day: 'numeric'
    });
  }
  return rtf.format(daysDifference, 'day');
};
---

<Layout
  title="Blog | Pablo."
  description="Artículos sobre desarrollo e ingeniería."
>
  <section class="reveal-text py-20 md:py-32">
    <header class="mb-16">
      <h1
        class="mb-6 text-4xl font-bold tracking-tight text-neutral-900 md:text-6xl dark:text-white"
      >
        Mi <span class="text-albero">Blog</span>.
      </h1>
      <p class="max-w-2xl text-lg text-neutral-600 dark:text-neutral-400">
        Escribo sobre código, diseño y opiniones.
      </p>
    </header>

    <div class="mb-12 flex flex-wrap gap-3">
      <button
        class="filter-btn active bg-albero border-albero rounded-full border px-5 py-2 text-sm font-semibold text-black transition-all duration-300 hover:scale-105 hover:bg-neutral-900 hover:text-white dark:hover:bg-white dark:hover:text-black"
        data-filter="all"
      >
        Todos
      </button>

      {
        categories.map((category) => (
          <button
            class="filter-btn hover:border-albero hover:text-albero dark:hover:border-albero dark:hover:text-albero rounded-full border border-neutral-300 bg-transparent px-5 py-2 text-sm font-medium text-neutral-600 transition-all duration-300 hover:scale-105 dark:border-white/20 dark:text-white"
            data-filter={category}
          >
            {category}
          </button>
        ))
      }
    </div>

    <div
      class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3"
      id="posts-grid"
    >
      {
        sortedPosts.map((post) => (
          <article
            class="post-card group flex h-full min-h-[220px] flex-col rounded-2xl border border-neutral-200 bg-neutral-50 p-6 transition-all duration-500 hover:bg-neutral-100 hover:shadow-xl dark:border-white/10 dark:bg-white/5 dark:hover:bg-[#151515] hover:-translate-y-1 dark:hover:border-albero/30"
            data-category={post.data.category}
          >
            <div class="mb-4 flex items-center justify-between">
              <span class="text-albero rounded-full bg-black/5 px-3 py-1 text-xs font-bold dark:bg-white/10">
                {post.data.category}
              </span>
              <time class="text-sm text-neutral-500 capitalize">
                {getRelativeDate(post.data.date)}
              </time>
            </div>

            <h2 class="mb-1 text-xl font-bold text-neutral-900 transition-colors duration-300 dark:text-white">
              <a
                href={`/blog/${post.slug}`}
                class="hover:text-albero dark:hover:text-albero transition-colors duration-300 focus:outline-none"
              >
                {post.data.title}
              </a>
            </h2>

            <div class="grid grid-rows-[0fr] opacity-0 transition-all duration-500 ease-in-out group-hover:grid-rows-[1fr] group-hover:mt-3 group-hover:opacity-100">
              <div class="overflow-hidden">
                <p class="text-sm leading-relaxed text-neutral-600 dark:text-neutral-400 line-clamp-2">
                  {post.data.description}
                </p>
              </div>
            </div>

            <a
              href={`/blog/${post.slug}`}
              class="hover:text-albero dark:hover:text-albero mt-auto flex w-fit items-center text-sm font-medium text-neutral-900 transition-colors duration-300 dark:text-white"
            >
              Leer artículo
              <svg
                class="ml-2 h-4 w-4 transition-transform duration-300 group-hover:translate-x-2"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M14 5l7 7m0 0l-7 7m7-7H3"
                />
              </svg>
            </a>
          </article>
        ))
      }
    </div>
  </section>
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const filterBtns = document.querySelectorAll(".filter-btn");
    const postCards = document.querySelectorAll(".post-card");

    // Arrays separados palabra por palabra para que JavaScript no se rompa
    const activeClasses = [
      "bg-albero",
      "text-black",
      "border-albero",
      "font-semibold",
      "active",
      "hover:bg-neutral-900",
      "hover:text-white",
      "dark:hover:bg-white",
      "dark:hover:text-black",
    ];

    const inactiveClasses = [
      "bg-transparent",
      "text-neutral-600",
      "dark:text-white",
      "border-neutral-300",
      "dark:border-white/20",
      "font-medium",
      "hover:border-albero",
      "hover:text-albero",
      "dark:hover:border-albero",
      "dark:hover:text-albero",
    ];

    filterBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        // 1. Reiniciar todos los botones al estado inactivo
        filterBtns.forEach((b) => {
          b.classList.remove(...activeClasses);
          b.classList.add(...inactiveClasses);
        });

        // 2. Aplicar estado activo al botón clicado
        btn.classList.remove(...inactiveClasses);
        btn.classList.add(...activeClasses);

        // 3. Filtrar las tarjetas
        const filterValue = btn.getAttribute("data-filter");

        postCards.forEach((card) => {
          const postCategory = card.getAttribute("data-category");

          if (filterValue === "all" || filterValue === postCategory) {
            (card as HTMLElement).style.display = "flex";
            (card as HTMLElement).style.animation =
              "fadeIn 0.5s ease-out forwards";
          } else {
            (card as HTMLElement).style.display = "none";
          }
        });
      });
    });
  });
</script>

<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
