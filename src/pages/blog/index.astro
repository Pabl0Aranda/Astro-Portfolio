---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog", ({ data }) => {
  return data.draft !== true;
});
const sortedPosts = allPosts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const categories = [...new Set(sortedPosts.map((post) => post.data.category))];
---

<Layout
  title="Blog | Pablo."
  description="Artículos sobre desarrollo e ingeniería."
>
  <section class="py-20 md:py-32 reveal-text">
    <header class="mb-16">
      <h1 class="text-4xl md:text-6xl font-bold tracking-tight mb-6">
        Mi <span class="text-albero">Blog</span>.
      </h1>
      <p class="text-lg text-neutral-400 max-w-2xl">
        Escribo sobre código, diseño y opiniones.
      </p>
    </header>

    <div class="flex flex-wrap gap-3 mb-12">
      <button
        class="filter-btn active px-5 py-2 rounded-full text-sm font-semibold border border-albero bg-albero text-black transition-all duration-300 hover:scale-105"
        data-filter="all"
      >
        Todos
      </button>

      {
        categories.map((category) => (
          <button
            class="filter-btn px-5 py-2 rounded-full text-sm font-medium border border-albero bg-albero text-black transition-all duration-300 hover:scale-105"
            data-filter={category}
          >
            {category}
          </button>
        ))
      }
    </div>

    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8"
      id="posts-grid"
    >
      {
        sortedPosts.map((post) => (
          <article
            class="post-card group border border-white/10 rounded-2xl p-6 bg-white/5 hover:border-albero/50 hover:bg-white/10 transition-all duration-300 flex flex-col h-full"
            data-category={post.data.category}
          >
            <div class="mb-4 flex justify-between items-center">
              <span class="text-xs font-bold px-3 py-1 bg-white/10 text-albero rounded-full">
                {post.data.category}
              </span>
              <time class="text-sm text-neutral-500">
                {post.data.date.toLocaleDateString("es-ES", {
                  year: "numeric",
                  month: "short",
                  day: "numeric",
                })}
              </time>
            </div>

            <h2 class="text-xl font-bold mb-3 transition-colors duration-300">
              <a
                href={`/blog/${post.slug}`}
                class="hover:text-albero focus:outline-none transition-colors duration-300"
              >
                {post.data.title}
              </a>
            </h2>

            <p class="text-neutral-400 text-sm leading-relaxed mb-6 flex">
              {post.data.description}
            </p>

            <a
              href={`/blog/${post.slug}`}
              class="mt-auto flex items-center text-sm font-medium text-white hover:text-albero transition-colors duration-300 w-fit"
            >
              Leer artículo
              <svg
                class="w-4 h-4 ml-2 group-hover:translate-x-2 transition-transform duration-300"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M14 5l7 7m0 0l-7 7m7-7H3"
                />
              </svg>
            </a>
          </article>
        ))
      }
    </div>
  </section>
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const filterBtns = document.querySelectorAll(".filter-btn");
    const postCards = document.querySelectorAll(".post-card");

    filterBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        // 1. Quitar estilos activos de todos los botones
        filterBtns.forEach((b) => {
          b.classList.remove(
            "bg-albero",
            "text-black",
            "border-albero",
            "font-semibold",
            "active",
          );
          b.classList.add(
            "bg-transparent",
            "text-white",
            "border-white/20",
            "font-medium",
          );
        });

        // 2. Poner estilo activo al botón clicado
        btn.classList.remove(
          "bg-transparent",
          "text-white",
          "border-white/20",
          "font-medium",
        );
        btn.classList.add(
          "bg-albero",
          "text-black",
          "border-albero",
          "font-semibold",
          "active",
        );

        // 3. Filtrar los posts
        const filterValue = btn.getAttribute("data-filter");

        postCards.forEach((card) => {
          const postCategory = card.getAttribute("data-category");

          if (filterValue === "all" || filterValue === postCategory) {
            // Mostrar tarjeta con una pequeña animación
            (card as HTMLElement).style.display = "flex";
            (card as HTMLElement).style.animation =
              "fadeIn 0.5s ease-out forwards";
          } else {
            // Ocultar tarjeta
            (card as HTMLElement).style.display = "none";
          }
        });
      });
    });
  });
</script>

<style>
  /* Pequeña animación para cuando reaparecen las tarjetas filtradas */
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
