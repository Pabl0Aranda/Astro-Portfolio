---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

// Generamos las rutas dinámicas para cada post
export async function getStaticPaths() {
  const blogEntries = await getCollection("blog");
  return blogEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Layout
  title={`${entry.data.title} | Pablo.`}
  description={entry.data.description}
>
  <div class="py-20 md:py-32 max-w-3xl mx-auto w-full px-6 md:px-0">
    <a
      href="/blog"
      class="inline-flex items-center text-albero hover:text-neutral-900 dark:text-white transition-colors duration-300 mb-10"
    >
      <svg
        class="w-4 h-4 mr-2"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
      </svg>
      Volver al blog
    </a>

    <header class="mb-14">
      <div class="flex items-center gap-3 mb-6">
        <span
          class="text-xs font-bold px-3 py-1 bg-neutral-50 dark:bg-white/10 text-albero rounded-full"
        >
          {entry.data.category}
        </span>
        <time class="text-sm text-neutral-500">
          {
            entry.data.date.toLocaleDateString("es-ES", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })
          }
        </time>
      </div>
      <h1
        class="text-3xl md:text-5xl font-bold tracking-tight mb-6 leading-tight"
      >
        {entry.data.title}
      </h1>
    </header>

    <article class="prose-custom w-full max-w-full break-words">
      <Content />
    </article>
  </div>
</Layout>

<style is:global>
  @reference "../../styles/global.css";

  .prose-custom {
    @apply text-neutral-300 leading-relaxed space-y-6 text-base;
  }
  @media (min-width: 768px) {
    .prose-custom {
      @apply text-lg;
    }
  }

  .prose-custom h2 {
    @apply text-2xl font-bold text-neutral-900 dark:text-white mt-12 mb-6 break-words;
  }
  @media (min-width: 768px) {
    .prose-custom h2 {
      @apply text-3xl;
    }
  }

  .prose-custom h3 {
    @apply text-xl font-bold text-neutral-900 dark:text-white mt-8 mb-4 break-words;
  }
  @media (min-width: 768px) {
    .prose-custom h3 {
      @apply text-2xl;
    }
  }

  /* Párrafos y listas */
  .prose-custom p {
    @apply mb-6 text-neutral-600 dark:text-neutral-400;
  }
  .prose-custom ul {
    @apply list-disc list-inside mb-6 space-y-2 text-neutral-600 dark:text-neutral-400;
  }
  .prose-custom ol {
    @apply list-decimal list-inside mb-6 space-y-2 text-neutral-600 dark:text-neutral-400;
  }

  /* Enlaces */
  .prose-custom a {
    @apply text-albero underline decoration-white/30 underline-offset-4 transition-colors break-words;
  }
  .prose-custom a:hover {
    @apply decoration-albero;
  }

  /* Citas (Blockquotes) */
  .prose-custom blockquote {
    @apply border-l-4 border-albero pl-4 italic text-neutral-600 dark:text-neutral-400 my-8 bg-neutral-50 dark:bg-white/5 py-2 pr-4 rounded-r-lg;
  }

  /* Bloques de código (Scroll horizontal en móvil) */
  .prose-custom pre {
    @apply max-w-full overflow-x-auto bg-[#1a1a1a] border border-neutral-200 dark:border-white/10 p-4 rounded-xl my-8 text-sm;
  }

  /* Código en línea (inline code) */
  .prose-custom code {
    @apply bg-white/10 text-albero px-1.5 py-0.5 rounded text-sm break-words;
  }
  .prose-custom pre code {
    @apply bg-transparent text-inherit p-0 rounded-none break-normal;
  }

  /* Imágenes */
  .prose-custom img {
    @apply max-w-full h-auto rounded-xl my-8 mx-auto border border-neutral-200 dark:border-white/10;
  }

  /* Tablas (Scroll horizontal en móvil) */
  .prose-custom table {
    @apply w-full max-w-full overflow-x-auto block border-collapse mb-8 text-sm text-neutral-600 dark:text-neutral-400;
  }
  @media (min-width: 768px) {
    .prose-custom table {
      @apply text-base;
    }
  }

  .prose-custom th,
  .prose-custom td {
    @apply border border-white/20 p-3 text-left min-w-[120px];
  }
  .prose-custom th {
    @apply bg-neutral-50 dark:bg-white/5 font-bold text-neutral-900 dark:text-white;
  }
</style>
