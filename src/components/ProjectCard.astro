---
import { getLangFromUrl } from "../i18n/ui";

interface Props {
  title: string;
  tech: string;
  link: string;
}

const { title, tech, link } = Astro.props;
const lang = getLangFromUrl(Astro.url);
---

<a
  href={link}
  target="_blank"
  rel="noopener noreferrer"
  class="group hover:border-albero dark:hover:border-albero block rounded-2xl border border-neutral-200 bg-neutral-50 p-8 transition-all duration-300 hover:bg-neutral-100 dark:border-white/10 dark:bg-white/5 dark:hover:bg-white/10"
>
  <h3
    class="group-hover:text-albero dark:group-hover:text-albero mb-2 text-2xl font-semibold text-neutral-900 transition-colors duration-300 dark:text-white"
  >
    {title}
  </h3>

  <p class="mb-6 text-sm text-neutral-600 dark:text-neutral-400">
    {tech}
  </p>

  <span
    class="group-hover:text-albero dark:group-hover:text-albero inline-flex items-center text-sm font-medium text-neutral-900 transition-colors duration-300 dark:text-white"
  >
    {lang === "es" ? "Ver proyecto" : "View project"}
    <svg
      class="ml-2 h-4 w-4 transition-transform duration-300 group-hover:translate-x-1"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
    </svg>
  </span>
</a>
