---
import { getLangFromUrl } from "../i18n/ui";

interface Props {
  title: string;
  tech: string;
  link: string;
}

const { title, tech, link } = Astro.props;
const lang = getLangFromUrl(Astro.url);
---

<a
  href={link}
  target="_blank"
  rel="noopener noreferrer"
  class="group block p-8 border border-neutral-200 dark:border-white/10 rounded-2xl hover:border-albero dark:hover:border-albero bg-neutral-50 dark:bg-white/5 hover:bg-neutral-100 dark:hover:bg-white/10 transition-all duration-300"
>
  <h3
    class="text-2xl font-semibold mb-2 text-neutral-900 dark:text-white group-hover:text-albero dark:group-hover:text-albero transition-colors duration-300"
  >
    {title}
  </h3>

  <p class="text-sm text-neutral-600 dark:text-neutral-400 mb-6">
    {tech}
  </p>

  <span
    class="inline-flex items-center text-sm font-medium text-neutral-900 dark:text-white group-hover:text-albero dark:group-hover:text-albero transition-colors duration-300"
  >
    {lang === "es" ? "Ver proyecto" : "View project"}
    <svg
      class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform duration-300"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
    </svg>
  </span>
</a>
