---
import { getLangFromUrl } from "../i18n/ui";

const lang = getLangFromUrl(Astro.url);
const searchPlaceholder = lang === "es" ? "Buscar artículos..." : "Search articles...";
---

<div id="search-modal" class="fixed inset-0 z-50 hidden bg-black/60 backdrop-blur-sm transition-opacity items-start justify-center pt-20 px-4 opacity-0">
  <div class="bg-white dark:bg-[#151515] w-full max-w-2xl rounded-2xl shadow-2xl border border-neutral-200 dark:border-white/10 overflow-hidden transform scale-95 transition-transform duration-300" id="search-container">
    <div class="p-4 border-b border-neutral-200 dark:border-white/10 flex justify-between items-center bg-neutral-50 dark:bg-black/20">
      <h3 class="text-lg font-bold text-neutral-900 dark:text-white">
        {lang === "es" ? "Buscar en el blog" : "Search the blog"}
      </h3>
      <button id="close-search" class="text-neutral-500 hover:text-black dark:text-neutral-400 dark:hover:text-white transition-colors p-1 rounded-md hover:bg-neutral-200 dark:hover:bg-white/10">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    
    <div class="p-6">
      <div id="search" class="w-full"></div>
    </div>
  </div>
</div>

<link href="/pagefind/pagefind-ui.css" rel="stylesheet">
<script is:inline src="/pagefind/pagefind-ui.js"></script>

<script define:vars={{ searchPlaceholder }}>
  document.addEventListener('astro:page-load', () => {
    // Inicializar Pagefind UI
    const searchElement = document.querySelector('#search');
    if (searchElement && window.PagefindUI && !searchElement.hasChildNodes()) {
      new window.PagefindUI({
        element: "#search",
        showSubResults: true,
        showImages: false,
        translations: {
          placeholder: searchPlaceholder,
          clear_search: "Limpiar / Clear",
          search_label: "Buscar / Search",
          filters_label: "Filtros / Filters",
          zero_results: "No se encontraron resultados / No results found para [SEARCH_TERM]",
          many_results: "[COUNT] resultados / results para [SEARCH_TERM]",
          one_result: "[COUNT] resultado / result para [SEARCH_TERM]",
          alt_search: "No se encontraron resultados para [SEARCH_TERM]. Mostrando resultados para [DIFFERENT_TERM] en su lugar",
          search_suggestion: "No se encontraron resultados para [SEARCH_TERM]. Intenta una de las siguientes búsquedas:",
          searching: "Buscando / Searching..."
        }
      });
    }

    const modal = document.getElementById('search-modal');
    const container = document.getElementById('search-container');
    const closeBtn = document.getElementById('close-search');
    const searchTriggers = document.querySelectorAll('.open-search'); // Elementos con esta clase abrirán el modal

    const openSearch = () => {
      modal.classList.remove('hidden');
      modal.style.display = 'flex';
      // Forzar un reflow para que la transición funcione
      void modal.offsetWidth;
      modal.classList.remove('opacity-0');
      modal.classList.add('opacity-100');
      container.classList.remove('scale-95');
      container.classList.add('scale-100');
      
      // Focus the input
      setTimeout(() => {
        const input = document.querySelector('#search input');
        if (input) input.focus();
      }, 100);
      
      document.body.style.overflow = 'hidden'; // Prevenir scroll de fondo
    };

    const closeSearch = () => {
      modal.classList.remove('opacity-100');
      modal.classList.add('opacity-0');
      container.classList.remove('scale-100');
      container.classList.add('scale-95');
      
      setTimeout(() => {
        modal.classList.add('hidden');
        modal.style.display = '';
        document.body.style.overflow = '';
      }, 300);
    };

    // Listeners para abrir
    searchTriggers.forEach(trigger => {
      trigger.addEventListener('click', (e) => {
        e.preventDefault();
        openSearch();
      });
    });

    // Listeners para cerrar
    closeBtn?.addEventListener('click', closeSearch);
    modal?.addEventListener('click', (e) => {
      if (e.target === modal) closeSearch();
    });
    
    // Abrir con Cmd+K o Ctrl+K
    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        if (modal.classList.contains('hidden')) {
          openSearch();
        } else {
          closeSearch();
        }
      }
      if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
        closeSearch();
      }
    });
  });
</script>

<style is:global>
  /* Customizar el aspecto de Pagefind para que encaje con tu diseño */
  :root {
    --pagefind-ui-scale: 1;
    --pagefind-ui-primary: #f2ca4b; /* color albero */
    --pagefind-ui-text: #171717;
    --pagefind-ui-background: #ffffff;
    --pagefind-ui-border: #e5e5e5;
    --pagefind-ui-tag: #f5f5f5;
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 0.5rem;
    --pagefind-ui-image-border-radius: 0.5rem;
    --pagefind-ui-image-box-ratio: 3 / 2;
    --pagefind-ui-font: inherit;
  }

  .dark {
    --pagefind-ui-primary: #f2ca4b; /* color albero */
    --pagefind-ui-text: #e5e5e5;
    --pagefind-ui-background: #151515;
    --pagefind-ui-border: rgba(255, 255, 255, 0.1);
    --pagefind-ui-tag: rgba(255, 255, 255, 0.05);
  }

  .pagefind-ui__search-input {
    font-weight: normal !important;
  }
  .pagefind-ui__result-title {
    font-weight: 700 !important;
  }
  .pagefind-ui__result-link {
    color: var(--pagefind-ui-text) !important;
    text-decoration: none !important;
    transition: color 0.2s;
  }
  .pagefind-ui__result-link:hover {
    color: var(--pagefind-ui-primary) !important;
  }
</style>
