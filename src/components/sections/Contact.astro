---
import { getLangFromUrl, useTranslations } from "../../i18n/ui";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section
  id="contacto"
  class="reveal-text border-t border-neutral-200 py-20 dark:border-white/10"
>
  <h2 class="mb-10 text-3xl font-bold text-neutral-900 dark:text-white">
    {t("contact.title")}
  </h2>

  <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:gap-8">
    <div class="flex flex-col justify-between">
      <div>
        <p
          class="mb-8 max-w-md leading-relaxed text-neutral-600 dark:text-neutral-400"
        >
          {t("contact.subtitle")}
        </p>
        <a
          href="mailto:pabloarandacortes02@gmail.com"
          class="hover:text-albero dark:hover:text-albero hover:decoration-albero reveal-text text-xl font-light text-neutral-900 underline decoration-neutral-300 underline-offset-8 transition-colors duration-300 md:text-2xl dark:text-white dark:decoration-white/30"
        >
          pabloarandacortes02@gmail.com
        </a>
      </div>

      <br />

      <div class="flex items-center gap-6">
        <a
          href="https://github.com/Pabl0Aranda"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-albero dark:hover:text-albero reveal-text text-neutral-600 transition-all duration-300 hover:-translate-y-1 dark:text-neutral-400"
          aria-label="GitHub"
        >
          <svg
            class="h-7 w-7 fill-current"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
            ></path>
          </svg>
        </a>

        <a
          href="https://www.linkedin.com/in/pablo-aranda-cort%C3%A9s-348783350/"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-albero dark:hover:text-albero reveal-text text-neutral-600 transition-all duration-300 hover:-translate-y-1 dark:text-neutral-400"
          aria-label="LinkedIn"
        >
          <svg
            class="h-7 w-7 fill-current"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
            ></path>
          </svg>
        </a>

        <a
          href="https://x.com/Pablo0aranda"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-albero dark:hover:text-albero reveal-text text-neutral-600 transition-all duration-300 hover:-translate-y-1 dark:text-neutral-400"
          aria-label="X"
        >
          <svg
            class="h-6 w-6 fill-current"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"
            ></path>
          </svg>
        </a>
      </div>
    </div>

    <form
      name="contacto"
      method="POST"
      action={lang === "es" ? "/" : "/en/"}
      data-netlify="true"
      data-astro-reload
      class="flex w-full max-w-lg flex-col gap-6 lg:ml-auto"
    >
      <input type="hidden" name="form-name" value="contacto" />

      <div>
        <label
          for="nombre"
          class="mb-2 block text-sm font-medium text-neutral-600 dark:text-neutral-400"
        >
          {t("contact.name_label")}
        </label>
        <input
          type="text"
          id="nombre"
          name="nombre"
          required
          class="focus:border-albero w-full rounded-lg border border-neutral-200 bg-neutral-50 px-4 py-3 text-neutral-900 transition-colors duration-300 focus:outline-none dark:border-white/10 dark:bg-white/5 dark:text-white"
          placeholder={t("contact.name_placeholder")}
        />
      </div>

      <div>
        <label
          for="email"
          class="mb-2 block text-sm font-medium text-neutral-600 dark:text-neutral-400"
        >
          Email
        </label>
        <input
          type="email"
          id="email"
          name="email"
          required
          class="focus:border-albero w-full rounded-lg border border-neutral-200 bg-neutral-50 px-4 py-3 text-neutral-900 transition-colors duration-300 focus:outline-none dark:border-white/10 dark:bg-white/5 dark:text-white"
          placeholder={t("contact.email_placeholder")}
        />
      </div>

      <div>
        <label
          for="mensaje"
          class="mb-2 block text-sm font-medium text-neutral-600 dark:text-neutral-400"
        >
          {t("contact.msg_label")}
        </label>
        <textarea
          id="mensaje"
          name="mensaje"
          rows="4"
          required
          class="focus:border-albero w-full resize-none rounded-lg border border-neutral-200 bg-neutral-50 px-4 py-3 text-neutral-900 transition-colors duration-300 focus:outline-none dark:border-white/10 dark:bg-white/5 dark:text-white"
          placeholder={t("contact.msg_placeholder")}></textarea>
      </div>

      <button
        type="submit"
        class="magnetic-btn hover:bg-albero dark:hover:bg-albero mt-2 w-full rounded-lg bg-neutral-900 px-8 py-3 font-semibold text-white transition-colors duration-300 hover:text-black sm:w-auto sm:self-end dark:bg-white dark:text-black"
      >
        {t("contact.submit")}
      </button>
    </form>
  </div>
</section>
