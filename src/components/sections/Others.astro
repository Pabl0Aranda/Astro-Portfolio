---
import { getLangFromUrl, useTranslations } from "../../i18n/ui";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section
  id="otros"
  class="border-t border-neutral-200 py-20 dark:border-white/10"
>
  <h2
    class="reveal-text mb-10 text-3xl font-bold text-neutral-900 dark:text-white"
  >
    {t("others.title")}
  </h2>

  <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
    <div
      class="hover:border-albero/50 reveal-card rounded-2xl border border-neutral-200 bg-neutral-50 p-8 transition-colors duration-300 dark:border-white/10 dark:bg-white/5"
    >
      <h3 class="text-albero mb-4 text-xl font-semibold">
        {t("others.languages_title")}
      </h3>
      <ul class="space-y-3 text-neutral-600 dark:text-neutral-400">
        <li class="flex items-center justify-between">
          <span class="text-neutral-900 dark:text-white">
            {t("others.spanish")}
          </span>
          <span
            class="rounded bg-neutral-200 px-2 py-1 text-sm font-medium text-neutral-800 dark:bg-white/10 dark:text-neutral-200"
          >
            {t("others.native")}
          </span>
        </li>
        <li class="flex items-center justify-between">
          <span class="text-neutral-900 dark:text-white">
            {t("others.english")}
          </span>
          <span
            class="rounded bg-neutral-200 px-2 py-1 text-sm font-medium text-neutral-800 dark:bg-white/10 dark:text-neutral-200"
          >
            B1 Cambridge
          </span>
        </li>
      </ul>
    </div>

    <div
      class="hover:border-albero/50 reveal-card rounded-2xl border border-neutral-200 bg-neutral-50 p-8 transition-colors duration-300 dark:border-white/10 dark:bg-white/5"
    >
      <h3 class="text-albero mb-4 text-xl font-semibold">
        {t("others.interests_title")}
      </h3>
      <p class="mb-4 leading-relaxed text-neutral-600 dark:text-neutral-400">
        {t("others.interests_desc")}
      </p>

      <div class="flex flex-wrap gap-2">
        <span
          class="rounded-full border border-neutral-300 px-3 py-1 text-xs text-neutral-700 dark:border-white/20 dark:text-neutral-300"
        >
          {t("others.photography")}
        </span>
        <span
          class="rounded-full border border-neutral-300 px-3 py-1 text-xs text-neutral-700 dark:border-white/20 dark:text-neutral-300"
        >
          {t("others.3d")}
        </span>
        <span
          class="rounded-full border border-neutral-300 px-3 py-1 text-xs text-neutral-700 dark:border-white/20 dark:text-neutral-300"
        >
          {t("others.architecture")}
        </span>
      </div>
    </div>
  </div>
</section>
