---
import { getLangFromUrl, useTranslations } from "../../i18n/ui";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="home" class="flex flex-col items-start gap-6 py-32">
  <h1
    class="text-5xl font-bold tracking-tight text-neutral-900 md:text-7xl dark:text-white"
  >
    {t("hero.greeting")}
    <span class="text-albero">Pablo</span>.
  </h1>

  <p
    class="reveal-text max-w-2xl text-lg leading-relaxed text-neutral-600 md:text-xl dark:text-neutral-400"
  >
    {t("hero.description1")}
    <b class="font-semibold text-neutral-900 dark:text-white">
      {t("hero.degree")}
    </b>
    {t("hero.description2")}
  </p>

  <div class="reveal-card mt-4 flex flex-wrap items-center gap-4">
    <a
      href="#contacto"
      class="hover:bg-albero dark:hover:bg-albero rounded-full bg-neutral-900 px-8 py-3 font-semibold text-white transition-colors duration-300 hover:text-black dark:bg-white dark:text-black"
    >
      {t("hero.contact")}
    </a>

    <a
      href={t("hero.cv_link")}
      download={t("hero.cv_name")}
      class="hover:border-albero hover:text-albero dark:hover:border-albero dark:hover:text-albero group flex items-center gap-2 rounded-full border border-neutral-300 bg-transparent px-8 py-3 font-semibold text-neutral-900 transition-colors duration-300 dark:border-white/20 dark:text-white"
    >
      {t("hero.download_cv")}
      <svg
        class="h-5 w-5 transition-transform duration-300 group-hover:translate-y-1"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
        ></path>
      </svg>
    </a>
  </div>
</section>
