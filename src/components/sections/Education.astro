---
import { getLangFromUrl, useTranslations } from "../../i18n/ui";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section
  id="formacion"
  class="border-t border-neutral-200 py-20 dark:border-white/10"
>
  <h2
    class="reveal-text mb-10 text-3xl font-bold text-neutral-900 dark:text-white"
  >
    {t("education.title")}
  </h2>

  <div
    class="ml-3 space-y-12 border-l border-neutral-300 md:ml-4 dark:border-white/20"
  >
    <div class="relative pl-8 md:pl-12">
      <div class="bg-albero absolute top-2 -left-[6.5px] h-3 w-3 rounded-full">
      </div>

      <h3
        class="reveal-text text-xl font-semibold text-neutral-900 dark:text-white"
      >
        {t("education.degree")}
      </h3>

      <p class="text-albero reveal-text mb-3 text-sm font-medium">
        {t("education.degree_date")}
      </p>

      <p
        class="reveal-text text-sm leading-relaxed text-neutral-600 md:text-base dark:text-neutral-400"
      >
        {t("education.degree_desc")}
      </p>
    </div>

    <div class="relative pl-8 md:pl-12">
      <div
        class="absolute top-2 -left-[6.5px] h-3 w-3 rounded-full bg-neutral-300 dark:bg-white/20"
      >
      </div>

      <h3
        class="reveal-text text-xl font-semibold text-neutral-900 dark:text-white"
      >
        {t("education.ml_title")}
      </h3>

      <p class="text-albero reveal-text mb-3 text-sm font-medium">
        {t("education.ml_date")}
      </p>

      <p
        class="reveal-text text-sm leading-relaxed text-neutral-600 md:text-base dark:text-neutral-400"
      >
      </p>
    </div>
  </div>
</section>
