---
import { getLangFromUrl } from "../../i18n/ui";

const lang = getLangFromUrl(Astro.url);
---

<section
  id="habilidades"
  class="py-20 border-t border-neutral-200 dark:border-white/10"
>
  <h2
    class="text-3xl font-bold mb-10 text-neutral-900 dark:text-white reveal-text"
  >
    {lang === "es" ? "Habilidades" : "Skills"}
  </h2>

  <h4 class="text-2xl font-bold mb-5 text-albero reveal-text">
    {lang === "es" ? "Desarrollo Web" : "Web Development"}
  </h4>
  <div class="flex flex-wrap gap-4 m-3 mb-10">
    <span
      class="px-5 py-2 border border-neutral-300 dark:border-white/10 rounded-full text-sm font-medium text-neutral-900 dark:text-white hover:border-albero hover:text-albero dark:hover:text-albero hover:bg-albero/5 dark:hover:bg-albero/5 transition-all duration-300 cursor-default reveal-text"
      >HTML5 & CSS3</span
    >
    <span
      class="px-5 py-2 border border-neutral-300 dark:border-white/10 rounded-full text-sm font-medium text-neutral-900 dark:text-white hover:border-albero hover:text-albero dark:hover:text-albero hover:bg-albero/5 dark:hover:bg-albero/5 transition-all duration-300 cursor-default reveal-text"
      >JavaScript</span
    >
    <span
      class="px-5 py-2 border border-neutral-300 dark:border-white/10 rounded-full text-sm font-medium text-neutral-900 dark:text-white hover:border-albero hover:text-albero dark:hover:text-albero hover:bg-albero/5 dark:hover:bg-albero/5 transition-all duration-300 cursor-default reveal-text"
      >JQuery</span
    >
    <span
      class="px-5 py-2 border border-neutral-300 dark:border-white/10 rounded-full text-sm font-medium text-neutral-900 dark:text-white hover:border-albero hover:text-albero dark:hover:text-albero hover:bg-albero/5 dark:hover:bg-albero/5 transition-all duration-300 cursor-default reveal-text"
      >PHP</span
    >
    <span
      class="px-5 py-2 border border-neutral-300 dark:border-white/10 rounded-full text-sm font-medium text-neutral-900 dark:text-white hover:border-albero hover:text-albero dark:hover:text-albero hover:bg-albero/5 dark:hover:bg-albero/5 transition-all duration-300 cursor-default reveal-text"
      >Angular</span
    >
    <span
      class="px-5 py-2 border border-neutral-300 dark:border-white/10 rounded-full text-sm font-medium text-neutral-900 dark:text-white hover:border-albero hover:text-albero dark:hover:text-albero hover:bg-albero/5 dark:hover:bg-albero/5 transition-all duration-300 cursor-default reveal-text"
      >Astro & Tailwind CSS</span
    >
    <span
      class="px-5 py-2 border border-neutral-300 dark:border-white/10 rounded-full text-sm font-medium text-neutral-900 dark:text-white hover:border-albero hover:text-albero dark:hover:text-albero hover:bg-albero/5 dark:hover:bg-albero/5 transition-all duration-300 cursor-default reveal-text"
      >Node JS & Express.js</span
    >
    <span
      class="px-5 py-2 border border-neutral-300 dark:border-white/10 rounded-full text-sm font-medium text-neutral-900 dark:text-white hover:border-albero hover:text-albero dark:hover:text-albero hover:bg-albero/5 dark:hover:bg-albero/5 transition-all duration-300 cursor-default reveal-text"
      >Django</span
    >
    <span
      class="px-5 py-2 border border-neutral-300 dark:border-white/10 rounded-full text-sm font-medium text-neutral-900 dark:text-white hover:border-albero hover:text-albero dark:hover:text-albero hover:bg-albero/5 dark:hover:bg-albero/5 transition-all duration-300 cursor-default reveal-text"
      >Java | Spring Boot [MVC, Data, Security]</span
    >
    <span
      class="px-5 py-2 border border-neutral-300 dark:border-white/10 rounded-full text-sm font-medium text-neutral-900 dark:text-white hover:border-albero hover:text-albero dark:hover:text-albero hover:bg-albero/5 dark:hover:bg-albero/5 transition-all duration-300 cursor-default reveal-text"
      >Hibernate</span
    >
  </div>

  <h4 class="text-2xl font-bold mb-5 text-albero reveal-text">
    Machine Learning
  </h4>
  <div class="flex flex-wrap gap-3 m-3 mb-10">
    <span
      class="px-5 py-2 border border-neutral-300 dark:border-white/10 rounded-full text-sm font-medium text-neutral-900 dark:text-white hover:border-albero hover:text-albero dark:hover:text-albero hover:bg-albero/5 dark:hover:bg-albero/5 transition-all duration-300 cursor-default reveal-text"
      >Python | Jupyter</span
    >
    <span
      class="px-5 py-2 border border-neutral-300 dark:border-white/10 rounded-full text-sm font-medium text-neutral-900 dark:text-white hover:border-albero hover:text-albero dark:hover:text-albero hover:bg-albero/5 dark:hover:bg-albero/5 transition-all duration-300 cursor-default reveal-text"
      >Pytorch</span
    >
    <span
      class="px-5 py-2 border border-neutral-300 dark:border-white/10 rounded-full text-sm font-medium text-neutral-900 dark:text-white hover:border-albero hover:text-albero dark:hover:text-albero hover:bg-albero/5 dark:hover:bg-albero/5 transition-all duration-300 cursor-default reveal-text"
      >Tensorflow</span
    >
    <span
      class="px-5 py-2 border border-neutral-300 dark:border-white/10 rounded-full text-sm font-medium text-neutral-900 dark:text-white hover:border-albero hover:text-albero dark:hover:text-albero hover:bg-albero/5 dark:hover:bg-albero/5 transition-all duration-300 cursor-default reveal-text"
      >Seaborn</span
    >
    <span
      class="px-5 py-2 border border-neutral-300 dark:border-white/10 rounded-full text-sm font-medium text-neutral-900 dark:text-white hover:border-albero hover:text-albero dark:hover:text-albero hover:bg-albero/5 dark:hover:bg-albero/5 transition-all duration-300 cursor-default reveal-text"
      >Pandas</span
    >
  </div>

  <h4 class="text-2xl font-bold mb-5 text-albero reveal-text">
    {lang === "es" ? "Bases de Datos y Software" : "Databases & Software"}
  </h4>
  <div class="flex flex-wrap gap-3 m-3 mb-10">
    <span
      class="px-5 py-2 border border-neutral-300 dark:border-white/10 rounded-full text-sm font-medium text-neutral-900 dark:text-white hover:border-albero hover:text-albero dark:hover:text-albero hover:bg-albero/5 dark:hover:bg-albero/5 transition-all duration-300 cursor-default reveal-text"
      >Odoo 19 Dev</span
    >
    <span
      class="px-5 py-2 border border-neutral-300 dark:border-white/10 rounded-full text-sm font-medium text-neutral-900 dark:text-white hover:border-albero hover:text-albero dark:hover:text-albero hover:bg-albero/5 dark:hover:bg-albero/5 transition-all duration-300 cursor-default reveal-text"
      >Java & Swing</span
    >
    <span
      class="px-5 py-2 border border-neutral-300 dark:border-white/10 rounded-full text-sm font-medium text-neutral-900 dark:text-white hover:border-albero hover:text-albero dark:hover:text-albero hover:bg-albero/5 dark:hover:bg-albero/5 transition-all duration-300 cursor-default reveal-text"
      >PostgreSQL</span
    >
    <span
      class="px-5 py-2 border border-neutral-300 dark:border-white/10 rounded-full text-sm font-medium text-neutral-900 dark:text-white hover:border-albero hover:text-albero dark:hover:text-albero hover:bg-albero/5 dark:hover:bg-albero/5 transition-all duration-300 cursor-default reveal-text"
      >MySQL</span
    >
    <span
      class="px-5 py-2 border border-neutral-300 dark:border-white/10 rounded-full text-sm font-medium text-neutral-900 dark:text-white hover:border-albero hover:text-albero dark:hover:text-albero hover:bg-albero/5 dark:hover:bg-albero/5 transition-all duration-300 cursor-default reveal-text"
      >MariaDB</span
    >
    <span
      class="px-5 py-2 border border-neutral-300 dark:border-white/10 rounded-full text-sm font-medium text-neutral-900 dark:text-white hover:border-albero hover:text-albero dark:hover:text-albero hover:bg-albero/5 dark:hover:bg-albero/5 transition-all duration-300 cursor-default reveal-text"
      >MongoDB</span
    >
  </div>

  <h4 class="text-2xl font-bold mb-5 text-albero reveal-text">
    {lang === "es" ? "Arquitecturas" : "Architectures"}
  </h4>
  <div class="flex flex-wrap gap-3 m-3 mb-10">
    <span
      class="px-5 py-2 border border-neutral-300 dark:border-white/10 rounded-full text-sm font-medium text-neutral-900 dark:text-white hover:border-albero hover:text-albero dark:hover:text-albero hover:bg-albero/5 dark:hover:bg-albero/5 transition-all duration-300 cursor-default reveal-text"
      >MVC</span
    >
    <span
      class="px-5 py-2 border border-neutral-300 dark:border-white/10 rounded-full text-sm font-medium text-neutral-900 dark:text-white hover:border-albero hover:text-albero dark:hover:text-albero hover:bg-albero/5 dark:hover:bg-albero/5 transition-all duration-300 cursor-default reveal-text"
      >EDA</span
    >
    <span
      class="px-5 py-2 border border-neutral-300 dark:border-white/10 rounded-full text-sm font-medium text-neutral-900 dark:text-white hover:border-albero hover:text-albero dark:hover:text-albero hover:bg-albero/5 dark:hover:bg-albero/5 transition-all duration-300 cursor-default reveal-text"
      >MVVM</span
    >
    <span
      class="px-5 py-2 border border-neutral-300 dark:border-white/10 rounded-full text-sm font-medium text-neutral-900 dark:text-white hover:border-albero hover:text-albero dark:hover:text-albero hover:bg-albero/5 dark:hover:bg-albero/5 transition-all duration-300 cursor-default reveal-text"
      >MVT</span
    >
    <span
      class="px-5 py-2 border border-neutral-300 dark:border-white/10 rounded-full text-sm font-medium text-neutral-900 dark:text-white hover:border-albero hover:text-albero dark:hover:text-albero hover:bg-albero/5 dark:hover:bg-albero/5 transition-all duration-300 cursor-default reveal-text"
      >Cliente - Servidor</span
    >
  </div>

  <h4 class="text-2xl font-bold mb-5 text-albero reveal-text">
    {lang === "es" ? "Herramientas" : "Tools"}
  </h4>
  <div class="flex flex-wrap gap-3 m-3 mb-10">
    <span
      class="px-5 py-2 border border-neutral-300 dark:border-white/10 rounded-full text-sm font-medium text-neutral-900 dark:text-white hover:border-albero hover:text-albero dark:hover:text-albero hover:bg-albero/5 dark:hover:bg-albero/5 transition-all duration-300 cursor-default reveal-text"
      >Git | GitHub</span
    >
    <span
      class="px-5 py-2 border border-neutral-300 dark:border-white/10 rounded-full text-sm font-medium text-neutral-900 dark:text-white hover:border-albero hover:text-albero dark:hover:text-albero hover:bg-albero/5 dark:hover:bg-albero/5 transition-all duration-300 cursor-default reveal-text"
      >Docker</span
    >
    <span
      class="px-5 py-2 border border-neutral-300 dark:border-white/10 rounded-full text-sm font-medium text-neutral-900 dark:text-white hover:border-albero hover:text-albero dark:hover:text-albero hover:bg-albero/5 dark:hover:bg-albero/5 transition-all duration-300 cursor-default reveal-text"
      >VS Code</span
    >
    <span
      class="px-5 py-2 border border-neutral-300 dark:border-white/10 rounded-full text-sm font-medium text-neutral-900 dark:text-white hover:border-albero hover:text-albero dark:hover:text-albero hover:bg-albero/5 dark:hover:bg-albero/5 transition-all duration-300 cursor-default reveal-text"
      >SQL Developer</span
    >
    <span
      class="px-5 py-2 border border-neutral-300 dark:border-white/10 rounded-full text-sm font-medium text-neutral-900 dark:text-white hover:border-albero hover:text-albero dark:hover:text-albero hover:bg-albero/5 dark:hover:bg-albero/5 transition-all duration-300 cursor-default reveal-text"
      >Entornos Linux</span
    >
    <span
      class="px-5 py-2 border border-neutral-300 dark:border-white/10 rounded-full text-sm font-medium text-neutral-900 dark:text-white hover:border-albero hover:text-albero dark:hover:text-albero hover:bg-albero/5 dark:hover:bg-albero/5 transition-all duration-300 cursor-default reveal-text"
      >Oracle Cloud | APEX</span
    >
  </div>

  <h4 class="text-2xl font-bold mb-5 text-albero reveal-text">
    {lang === "es" ? "Metodologías" : "Methodologies"}
  </h4>
  <div class="flex flex-wrap gap-3 m-3">
    <span
      class="px-5 py-2 border border-neutral-300 dark:border-white/10 rounded-full text-sm font-medium text-neutral-900 dark:text-white hover:border-albero hover:text-albero dark:hover:text-albero hover:bg-albero/5 dark:hover:bg-albero/5 transition-all duration-300 cursor-default reveal-text"
      >Agile | Kanban & SCRUM</span
    >
    <span
      class="px-5 py-2 border border-neutral-300 dark:border-white/10 rounded-full text-sm font-medium text-neutral-900 dark:text-white hover:border-albero hover:text-albero dark:hover:text-albero hover:bg-albero/5 dark:hover:bg-albero/5 transition-all duration-300 cursor-default reveal-text"
      >Métrica V3</span
    >
  </div>
</section>
