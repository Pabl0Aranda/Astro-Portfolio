---
import { getLangFromUrl, useTranslations } from "../i18n/ui";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const prefix = lang === "es" ? "" : "/en";

const commands = [
  { id: 'home', name: t("nav.home") || 'Inicio', icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6', url: `${prefix}/#home` },
  { id: 'projects', name: t("nav.proyectos") || 'Proyectos', icon: 'M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z', url: `${prefix}/#proyectos` },
  { id: 'blog', name: t("nav.blog") || 'Blog', icon: 'M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z', url: `${prefix}/blog` },
  { id: 'contact', name: t("nav.contacto") || 'Contacto', icon: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z', url: `${prefix}/#contacto` },
  { id: 'theme', name: lang === "es" ? 'Alternar Tema Oscuro/Claro' : 'Toggle Dark/Light Theme', icon: 'M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z', action: 'theme' }
];
---

<div id="cmd-palette-backdrop" class="fixed inset-0 z-[100] hidden flex-col bg-black/40 backdrop-blur-sm transition-opacity duration-300 opacity-0 items-center pt-[15vh]">
  <div id="cmd-palette" class="w-full max-w-xl scale-95 opacity-0 transition-all duration-300 bg-white dark:bg-[#111] border border-neutral-200 dark:border-white/10 rounded-2xl shadow-2xl overflow-hidden flex flex-col">
    <div class="flex items-center px-4 py-3 border-b border-neutral-200 dark:border-white/10">
      <svg class="w-5 h-5 text-neutral-400 mr-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
      </svg>
      <input 
        type="text" 
        id="cmd-input" 
        class="w-full bg-transparent text-neutral-900 dark:text-white placeholder-neutral-400 focus:outline-none text-lg"
        placeholder={lang === "es" ? "Busca algo o navega..." : "Search or navigate..."}
        autocomplete="off"
      />
      <button id="cmd-close" class="text-xs bg-neutral-100 dark:bg-white/10 text-neutral-500 dark:text-neutral-400 px-2 py-1 rounded-md ml-3 hover:bg-neutral-200 dark:hover:bg-white/20 transition-colors shrink-0">
        ESC
      </button>
    </div>
    
    <div class="max-h-[50vh] overflow-y-auto p-2" id="cmd-results">
      {commands.map((cmd, index) => (
        <button 
          class="cmd-item w-full flex items-center px-4 py-3 rounded-xl text-left transition-colors group focus:outline-none"
          data-url={cmd.url}
          data-action={cmd.action}
          data-index={index}
        >
          <svg class="w-5 h-5 text-neutral-400 group-hover:text-albero group-[.selected]:text-albero mr-3 transition-colors shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={cmd.icon} />
          </svg>
          <span class="text-neutral-700 dark:text-neutral-300 group-[.selected]:text-neutral-900 dark:group-[.selected]:text-white font-medium transition-colors">
            {cmd.name}
          </span>
          <span class="ml-auto text-xs text-neutral-400 opacity-0 group-[.selected]:opacity-100 transition-opacity">↵ Enter</span>
        </button>
      ))}
    </div>
  </div>
</div>

<script>
  document.addEventListener("astro:page-load", () => {
    const backdrop = document.getElementById("cmd-palette-backdrop");
    const palette = document.getElementById("cmd-palette");
    const input = document.getElementById("cmd-input") as HTMLInputElement;
    const closeBtn = document.getElementById("cmd-close");
    const items = Array.from(document.querySelectorAll(".cmd-item")) as HTMLElement[];
    
    if (!backdrop || !palette || !input) return;

    let isOpen = false;
    let selectedIndex = 0;

    const openPalette = () => {
      isOpen = true;
      backdrop.classList.remove("hidden");
      backdrop.classList.add("flex");
      // Trigger reflow
      void backdrop.offsetWidth;
      backdrop.classList.remove("opacity-0");
      backdrop.classList.add("opacity-100");
      
      palette.classList.remove("scale-95", "opacity-0");
      palette.classList.add("scale-100", "opacity-100");
      
      input.value = "";
      input.focus();
      filterItems("");
      updateSelection();
    };

    const closePalette = () => {
      isOpen = false;
      backdrop.classList.remove("opacity-100");
      backdrop.classList.add("opacity-0");
      
      palette.classList.remove("scale-100", "opacity-100");
      palette.classList.add("scale-95", "opacity-0");
      
      setTimeout(() => {
        backdrop.classList.remove("flex");
        backdrop.classList.add("hidden");
      }, 300);
    };

    const updateSelection = () => {
      const visibleItems = items.filter(item => !item.classList.contains("hidden"));
      items.forEach(item => {
        item.classList.remove("selected", "bg-neutral-100", "dark:bg-white/5");
      });
      if (visibleItems[selectedIndex]) {
        visibleItems[selectedIndex].classList.add("selected", "bg-neutral-100", "dark:bg-white/5");
      }
    };

    const executeAction = (item: HTMLElement) => {
      const url = item.getAttribute("data-url");
      const action = item.getAttribute("data-action");
      
      closePalette();
      
      if (url) {
        window.location.href = url;
      } else if (action === "theme") {
        const element = document.documentElement;
        element.classList.toggle("dark");
        const isDark = element.classList.contains("dark");
        localStorage.setItem("theme", isDark ? "dark" : "light");
      }
    };

    const filterItems = (query: string) => {
      const q = query.toLowerCase();
      let visibleCount = 0;
      items.forEach(item => {
        const text = item.textContent?.toLowerCase() || "";
        if (text.includes(q)) {
          item.classList.remove("hidden");
          visibleCount++;
        } else {
          item.classList.add("hidden");
        }
      });
      selectedIndex = 0;
      updateSelection();
    };

    // Event Listeners
    document.addEventListener("keydown", (e) => {
      if ((e.ctrlKey || e.metaKey) && e.key === "k") {
        e.preventDefault();
        isOpen ? closePalette() : openPalette();
      }
      
      if (!isOpen) return;

      if (e.key === "Escape") {
        closePalette();
      } else if (e.key === "ArrowDown") {
        e.preventDefault();
        const visibleItems = items.filter(item => !item.classList.contains("hidden"));
        if (visibleItems.length > 0) {
          selectedIndex = (selectedIndex + 1) % visibleItems.length;
          updateSelection();
        }
      } else if (e.key === "ArrowUp") {
        e.preventDefault();
        const visibleItems = items.filter(item => !item.classList.contains("hidden"));
        if (visibleItems.length > 0) {
          selectedIndex = (selectedIndex - 1 + visibleItems.length) % visibleItems.length;
          updateSelection();
        }
      } else if (e.key === "Enter") {
        e.preventDefault();
        const visibleItems = items.filter(item => !item.classList.contains("hidden"));
        if (visibleItems.length > 0) {
          executeAction(visibleItems[selectedIndex]);
        }
      }
    });

    input.addEventListener("input", (e) => {
      filterItems((e.target as HTMLInputElement).value);
    });

    backdrop.addEventListener("click", (e) => {
      if (e.target === backdrop) closePalette();
    });

    if (closeBtn) {
      closeBtn.addEventListener("click", closePalette);
    }

    items.forEach(item => {
      item.addEventListener("mouseenter", () => {
        const visibleItems = items.filter(i => !i.classList.contains("hidden"));
        const idx = visibleItems.indexOf(item);
        if (idx !== -1) {
          selectedIndex = idx;
          updateSelection();
        }
      });
      item.addEventListener("click", () => executeAction(item));
    });
  });
</script>
