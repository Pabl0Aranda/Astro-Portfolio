---
import { getLangFromUrl, useTranslations } from "../i18n/ui";

// 1. Obtenemos el idioma actual basado en la URL
const lang = getLangFromUrl(Astro.url);
// 2. Cargamos la función de traducción para ese idioma
const t = useTranslations(lang);

// 3. Lógica para el botón de cambiar idioma (mantiene la ruta actual)
const currentPath = Astro.url.pathname;
const switchLangUrl =
  lang === "es"
    ? `/en${currentPath === "/" ? "" : currentPath}`
    : currentPath.replace(/^\/en/, "") || "/";

// 4. Prefijo para los enlaces (si estamos en inglés, los enlaces deben ir a /en/#seccion)
const prefix = lang === "es" ? "" : "/en";
---

<header
  class="sticky top-0 z-50 w-full border-b border-neutral-200 bg-white/80 backdrop-blur-md transition-colors duration-300 dark:border-white/10 dark:bg-black/80"
>
  <div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
    <a
      href={`${prefix}/`}
      class="hover:text-albero dark:hover:text-albero text-xl font-bold tracking-tighter text-neutral-900 transition-colors duration-300 dark:text-white"
    >
      Pablo<span class="text-albero">.</span>
    </a>

    <nav class="hidden lg:block">
      <ul class="flex items-center gap-6 text-sm font-medium">
        <li>
          <a
            href={`${prefix}/#home`}
            class="hover:text-albero dark:hover:text-albero text-neutral-600 transition-colors duration-300 dark:text-neutral-300"
            >{t("nav.home")}</a
          >
        </li>
        <li>
          <a
            href={`${prefix}/#formacion`}
            class="hover:text-albero dark:hover:text-albero text-neutral-600 transition-colors duration-300 dark:text-neutral-300"
            >{t("nav.formacion")}</a
          >
        </li>
        <li>
          <a
            href={`${prefix}/#habilidades`}
            class="hover:text-albero dark:hover:text-albero text-neutral-600 transition-colors duration-300 dark:text-neutral-300"
            >{t("nav.habilidades")}</a
          >
        </li>
        <li>
          <a
            href={`${prefix}/#proyectos`}
            class="hover:text-albero dark:hover:text-albero text-neutral-600 transition-colors duration-300 dark:text-neutral-300"
            >{t("nav.proyectos")}</a
          >
        </li>
        <li>
          <a
            href={`${prefix}/#experiencia`}
            class="hover:text-albero dark:hover:text-albero text-neutral-600 transition-colors duration-300 dark:text-neutral-300"
            >{t("nav.experiencia")}</a
          >
        </li>
        <li>
          <a
            href={`${prefix}/#contacto`}
            class="hover:text-albero dark:hover:text-albero text-neutral-600 transition-colors duration-300 dark:text-neutral-300"
            >{t("nav.contacto")}</a
          >
        </li>
        <li>
          <a
            href={`${prefix}/blog`}
            class="text-albero font-bold transition-colors duration-300"
            >{t("nav.blog")}</a
          >
        </li>
      </ul>
    </nav>

    <div class="flex items-center gap-3">
      <a
        href={switchLangUrl}
        class="hover:text-albero dark:hover:text-albero flex h-9 w-9 items-center justify-center rounded-full bg-neutral-100 text-xs font-bold text-neutral-600 transition-all hover:scale-110 dark:bg-white/10 dark:text-neutral-400"
        aria-label="Cambiar idioma"
      >
        {lang === "es" ? "EN" : "ES"}
      </a>

      <button
        id="theme-toggle"
        class="hover:text-albero dark:hover:text-albero rounded-full bg-neutral-100 p-2 text-neutral-600 transition-all hover:scale-110 dark:bg-white/10 dark:text-neutral-400"
        aria-label="Cambiar tema"
      >
        <svg
          id="theme-toggle-light-icon"
          class="hidden h-5 w-5 dark:block"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"
          ></path>
        </svg>
        <svg
          id="theme-toggle-dark-icon"
          class="block h-5 w-5 dark:hidden"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
          ></path>
        </svg>
      </button>

      <button
        id="menu-open"
        class="hover:text-albero dark:hover:text-albero p-2 text-neutral-900 transition-colors focus:outline-none lg:hidden dark:text-white"
        aria-label="Abrir menú"
      >
        <svg
          class="h-6 w-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Barra de progreso de lectura -->
  <div class="absolute bottom-0 left-0 h-[3px] w-full bg-transparent">
    <div
      id="progress-bar"
      class="bg-albero h-full w-0 transition-all duration-150 ease-out"
    >
    </div>
  </div>
</header>

<div
  id="mobile-menu"
  class="pointer-events-none fixed inset-0 z-100 flex flex-col bg-white opacity-0 transition-all duration-300 lg:hidden dark:bg-black"
>
  <div
    class="flex items-center justify-between border-b border-neutral-200 px-6 py-4 dark:border-white/10"
  >
    <a
      href={`${prefix}/`}
      class="text-xl font-bold tracking-tighter text-neutral-900 dark:text-white"
    >
      Pablo<span class="text-albero">.</span>
    </a>
    <button
      id="menu-close"
      class="p-2 text-neutral-900 focus:outline-none dark:text-white"
      aria-label="Cerrar menú"
    >
      <svg
        class="hover:text-albero h-7 w-7 transition-colors"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </div>

  <nav class="flex grow flex-col items-center justify-center pb-20">
    <ul class="flex flex-col gap-8 text-center text-2xl font-semibold">
      <li>
        <a
          href={`${prefix}/#`}
          class="mobile-link hover:text-albero text-neutral-900 transition-colors duration-300 dark:text-white"
          >{t("nav.home")}</a
        >
      </li>
      <li>
        <a
          href={`${prefix}/#formacion`}
          class="mobile-link hover:text-albero text-neutral-900 transition-colors duration-300 dark:text-white"
          >{t("nav.formacion")}</a
        >
      </li>
      <li>
        <a
          href={`${prefix}/#habilidades`}
          class="mobile-link hover:text-albero text-neutral-900 transition-colors duration-300 dark:text-white"
          >{t("nav.habilidades")}</a
        >
      </li>
      <li>
        <a
          href={`${prefix}/#proyectos`}
          class="mobile-link hover:text-albero text-neutral-900 transition-colors duration-300 dark:text-white"
          >{t("nav.proyectos")}</a
        >
      </li>
      <li>
        <a
          href={`${prefix}/#experiencia`}
          class="mobile-link hover:text-albero text-neutral-900 transition-colors duration-300 dark:text-white"
          >{t("nav.experiencia")}</a
        >
      </li>
      <li>
        <a
          href={`${prefix}/#contacto`}
          class="mobile-link hover:text-albero text-neutral-900 transition-colors duration-300 dark:text-white"
          >{t("nav.contacto")}</a
        >
      </li>
      <li>
        <a href={`${prefix}/blog`} class="mobile-link text-albero mt-4 block"
          >{t("nav.blog")}</a
        >
      </li>
    </ul>
  </nav>
</div>

<script>
  document.addEventListener("astro:page-load", () => {
    // 1. Menú Móvil
    const btnOpen = document.getElementById("menu-open");
    const btnClose = document.getElementById("menu-close");
    const mobileMenu = document.getElementById("mobile-menu");
    const mobileLinks = document.querySelectorAll(".mobile-link");

    function openMenu() {
      if (!mobileMenu) return;
      mobileMenu.classList.remove("opacity-0", "pointer-events-none");
      mobileMenu.classList.add("opacity-100", "pointer-events-auto");
      document.body.style.overflow = "hidden";
    }

    function closeMenu() {
      if (!mobileMenu) return;
      mobileMenu.classList.remove("opacity-100", "pointer-events-auto");
      mobileMenu.classList.add("opacity-0", "pointer-events-none");
      document.body.style.overflow = "auto";
    }

    if (btnOpen) btnOpen.addEventListener("click", openMenu);
    if (btnClose) btnClose.addEventListener("click", closeMenu);
    mobileLinks.forEach((link) => link.addEventListener("click", closeMenu));

    // 2. Modo Oscuro
    const themeToggle = document.getElementById("theme-toggle");
    const handleToggleClick = () => {
      const element = document.documentElement;
      element.classList.toggle("dark");
      const isDark = element.classList.contains("dark");
      localStorage.setItem("theme", isDark ? "dark" : "light");
    };
    if (themeToggle) themeToggle.onclick = handleToggleClick;

    // 3. Barra de Progreso de Lectura
    const progressBar = document.getElementById("progress-bar");
    if (progressBar) {
      const updateProgress = () => {
        const scrollTop = window.scrollY || document.documentElement.scrollTop;
        const scrollHeight =
          document.documentElement.scrollHeight -
          document.documentElement.clientHeight;
        const scrollPercentage =
          scrollHeight > 0 ? (scrollTop / scrollHeight) * 100 : 0;
        progressBar.style.width = `${scrollPercentage}%`;
      };

      window.addEventListener("scroll", updateProgress);
      // Llamar una vez al cargar por si no estamos arriba del todo
      updateProgress();
    }
  });
</script>
