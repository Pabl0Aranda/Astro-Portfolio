<header
  class="w-full border-b border-white/10 sticky top-0 bg-black/80 backdrop-blur-md z-50"
>
  <div class="max-w-5xl mx-auto px-6 py-4 flex justify-between items-center">
    <a
      href="/"
      class="text-xl font-bold tracking-tighter text-white hover:text-albero transition-colors duration-300"
    >
      Pablo<span class="text-albero">.</span>
    </a>

    <nav class="hidden lg:block">
      <ul class="flex gap-5 text-sm font-medium">
        <li>
          <a href="/#" class="hover:text-albero transition-colors duration-300"
            >Home</a
          >
        </li>
        <li>
          <a
            href="/#formacion"
            class="hover:text-albero transition-colors duration-300"
            >Formación</a
          >
        </li>
        <li>
          <a
            href="/#habilidades"
            class="hover:text-albero transition-colors duration-300"
            >Habilidades</a
          >
        </li>
        <li>
          <a
            href="/#proyectos"
            class="hover:text-albero transition-colors duration-300"
            >Proyectos</a
          >
        </li>
        <li>
          <a
            href="/#experiencia"
            class="hover:text-albero transition-colors duration-300"
            >Experiencia</a
          >
        </li>
        <li>
          <a
            href="/#contacto"
            class="hover:text-albero transition-colors duration-300">Contacto</a
          >
        </li>
        <li>
          <a href="/blog" class="text-albero transition-colors duration-300"
            >Blog</a
          >
        </li>
      </ul>
    </nav>

    <button
      id="menu-open"
      class="lg:hidden text-white p-2 focus:outline-none"
      aria-label="Abrir menú"
    >
      <svg
        class="w-6 h-6"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </div>
</header>

<div
  id="mobile-menu"
  class="fixed inset-0 bg-black z-100 flex flex-col opacity-0 pointer-events-none transition-opacity duration-300 lg:hidden"
>
  <div
    class="px-6 py-4 flex justify-between items-center border-b border-white/10"
  >
    <a href="/" class="text-xl font-bold tracking-tighter text-white">
      Pablo<span class="text-albero">.</span>
    </a>
    <button
      id="menu-close"
      class="text-white p-2 focus:outline-none"
      aria-label="Cerrar menú"
    >
      <svg
        class="w-7 h-7 hover:text-albero transition-colors"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </div>

  <nav class="grow flex flex-col items-center justify-center pb-20">
    <ul class="flex flex-col gap-8 text-center text-2xl font-semibold">
      <li>
        <a
          href="/#"
          class="mobile-link hover:text-albero transition-colors duration-300"
          >Home</a
        >
      </li>
      <li>
        <a
          href="/#formacion"
          class="mobile-link hover:text-albero transition-colors duration-300"
          >Formación</a
        >
      </li>
      <li>
        <a
          href="/#habilidades"
          class="mobile-link hover:text-albero transition-colors duration-300"
          >Habilidades</a
        >
      </li>
      <li>
        <a
          href="/#proyectos"
          class="mobile-link hover:text-albero transition-colors duration-300"
          >Proyectos</a
        >
      </li>
      <li>
        <a
          href="/#experiencia"
          class="mobile-link hover:text-albero transition-colors duration-300"
          >Experiencia</a
        >
      </li>
      <li>
        <a
          href="/#contacto"
          class="mobile-link hover:text-albero transition-colors duration-300"
          >Contacto</a
        >
      </li>
      <li>
        <a href="/blog" class="mobile-link text-albero mt-4 block">Blog</a>
      </li>
    </ul>
  </nav>
</div>

<script>
  // Envolvemos el código del menú en el evento de Astro
  document.addEventListener("astro:page-load", () => {
    const btnOpen = document.getElementById("menu-open");
    const btnClose = document.getElementById("menu-close");
    const mobileMenu = document.getElementById("mobile-menu");
    const mobileLinks = document.querySelectorAll(".mobile-link");

    function openMenu() {
      if (!mobileMenu) return;
      mobileMenu.classList.remove("opacity-0", "pointer-events-none");
      mobileMenu.classList.add("opacity-100", "pointer-events-auto");
      document.body.style.overflow = "hidden";
    }

    function closeMenu() {
      if (!mobileMenu) return;
      mobileMenu.classList.remove("opacity-100", "pointer-events-auto");
      mobileMenu.classList.add("opacity-0", "pointer-events-none");
      document.body.style.overflow = "auto";
    }

    if (btnOpen) btnOpen.addEventListener("click", openMenu);
    if (btnClose) btnClose.addEventListener("click", closeMenu);

    mobileLinks.forEach((link) => {
      link.addEventListener("click", closeMenu);
    });
  });
</script>
