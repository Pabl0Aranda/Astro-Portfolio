---
import { getLangFromUrl, useTranslations } from "../i18n/ui";

// 1. Obtenemos el idioma actual basado en la URL
const lang = getLangFromUrl(Astro.url);
// 2. Cargamos la función de traducción para ese idioma
const t = useTranslations(lang);

// 3. Lógica para el botón de cambiar idioma (mantiene la ruta actual)
const currentPath = Astro.url.pathname;
const switchLangUrl =
  lang === "es"
    ? `/en${currentPath === "/" ? "" : currentPath}`
    : currentPath.replace(/^\/en/, "") || "/";

// 4. Prefijo para los enlaces (si estamos en inglés, los enlaces deben ir a /en/#seccion)
const prefix = lang === "es" ? "" : "/en";
---

<header
  class="w-full border-b border-neutral-200 dark:border-white/10 sticky top-0 bg-white/80 dark:bg-black/80 backdrop-blur-md z-50 transition-colors duration-300"
>
  <div class="max-w-5xl mx-auto px-6 py-4 flex justify-between items-center">
    <a
      href={`${prefix}/`}
      class="text-xl font-bold tracking-tighter text-neutral-900 dark:text-white hover:text-albero dark:hover:text-albero transition-colors duration-300"
    >
      Pablo<span class="text-albero">.</span>
    </a>

    <nav class="hidden lg:block">
      <ul class="flex items-center gap-6 text-sm font-medium">
        <li>
          <a
            href={`${prefix}/#home`}
            class="text-neutral-600 dark:text-neutral-300 hover:text-albero dark:hover:text-albero transition-colors duration-300"
            >{t("nav.home")}</a
          >
        </li>
        <li>
          <a
            href={`${prefix}/#formacion`}
            class="text-neutral-600 dark:text-neutral-300 hover:text-albero dark:hover:text-albero transition-colors duration-300"
            >{t("nav.formacion")}</a
          >
        </li>
        <li>
          <a
            href={`${prefix}/#habilidades`}
            class="text-neutral-600 dark:text-neutral-300 hover:text-albero dark:hover:text-albero transition-colors duration-300"
            >{t("nav.habilidades")}</a
          >
        </li>
        <li>
          <a
            href={`${prefix}/#proyectos`}
            class="text-neutral-600 dark:text-neutral-300 hover:text-albero dark:hover:text-albero transition-colors duration-300"
            >{t("nav.proyectos")}</a
          >
        </li>
        <li>
          <a
            href={`${prefix}/#experiencia`}
            class="text-neutral-600 dark:text-neutral-300 hover:text-albero dark:hover:text-albero transition-colors duration-300"
            >{t("nav.experiencia")}</a
          >
        </li>
        <li>
          <a
            href={`${prefix}/#contacto`}
            class="text-neutral-600 dark:text-neutral-300 hover:text-albero dark:hover:text-albero transition-colors duration-300"
            >{t("nav.contacto")}</a
          >
        </li>
        <li>
          <a
            href={`${prefix}/blog`}
            class="text-albero font-bold transition-colors duration-300"
            >{t("nav.blog")}</a
          >
        </li>
      </ul>
    </nav>

    <div class="flex items-center gap-3">
      <a
        href={switchLangUrl}
        class="w-9 h-9 flex items-center justify-center rounded-full bg-neutral-100 dark:bg-white/10 text-xs font-bold text-neutral-600 dark:text-neutral-400 hover:text-albero dark:hover:text-albero hover:scale-110 transition-all"
        aria-label="Cambiar idioma"
      >
        {lang === "es" ? "EN" : "ES"}
      </a>

      <button
        id="theme-toggle"
        class="p-2 rounded-full bg-neutral-100 dark:bg-white/10 text-neutral-600 dark:text-neutral-400 hover:text-albero dark:hover:text-albero transition-all hover:scale-110"
        aria-label="Cambiar tema"
      >
        <svg
          id="theme-toggle-light-icon"
          class="w-5 h-5 hidden dark:block"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"
          ></path>
        </svg>
        <svg
          id="theme-toggle-dark-icon"
          class="w-5 h-5 block dark:hidden"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
          ></path>
        </svg>
      </button>

      <button
        id="menu-open"
        class="lg:hidden text-neutral-900 dark:text-white p-2 focus:outline-none hover:text-albero dark:hover:text-albero transition-colors"
        aria-label="Abrir menú"
      >
        <svg
          class="w-6 h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </div>
</header>

<div
  id="mobile-menu"
  class="fixed inset-0 bg-white dark:bg-black z-100 flex flex-col opacity-0 pointer-events-none transition-all duration-300 lg:hidden"
>
  <div
    class="px-6 py-4 flex justify-between items-center border-b border-neutral-200 dark:border-white/10"
  >
    <a
      href={`${prefix}/`}
      class="text-xl font-bold tracking-tighter text-neutral-900 dark:text-white"
    >
      Pablo<span class="text-albero">.</span>
    </a>
    <button
      id="menu-close"
      class="text-neutral-900 dark:text-white p-2 focus:outline-none"
      aria-label="Cerrar menú"
    >
      <svg
        class="w-7 h-7 hover:text-albero transition-colors"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </div>

  <nav class="grow flex flex-col items-center justify-center pb-20">
    <ul class="flex flex-col gap-8 text-center text-2xl font-semibold">
      <li>
        <a
          href={`${prefix}/#`}
          class="mobile-link text-neutral-900 dark:text-white hover:text-albero transition-colors duration-300"
          >{t("nav.home")}</a
        >
      </li>
      <li>
        <a
          href={`${prefix}/#formacion`}
          class="mobile-link text-neutral-900 dark:text-white hover:text-albero transition-colors duration-300"
          >{t("nav.formacion")}</a
        >
      </li>
      <li>
        <a
          href={`${prefix}/#habilidades`}
          class="mobile-link text-neutral-900 dark:text-white hover:text-albero transition-colors duration-300"
          >{t("nav.habilidades")}</a
        >
      </li>
      <li>
        <a
          href={`${prefix}/#proyectos`}
          class="mobile-link text-neutral-900 dark:text-white hover:text-albero transition-colors duration-300"
          >{t("nav.proyectos")}</a
        >
      </li>
      <li>
        <a
          href={`${prefix}/#experiencia`}
          class="mobile-link text-neutral-900 dark:text-white hover:text-albero transition-colors duration-300"
          >{t("nav.experiencia")}</a
        >
      </li>
      <li>
        <a
          href={`${prefix}/#contacto`}
          class="mobile-link text-neutral-900 dark:text-white hover:text-albero transition-colors duration-300"
          >{t("nav.contacto")}</a
        >
      </li>
      <li>
        <a href={`${prefix}/blog`} class="mobile-link text-albero mt-4 block"
          >{t("nav.blog")}</a
        >
      </li>
    </ul>
  </nav>
</div>

<script>
  document.addEventListener("astro:page-load", () => {
    // 1. Menú Móvil
    const btnOpen = document.getElementById("menu-open");
    const btnClose = document.getElementById("menu-close");
    const mobileMenu = document.getElementById("mobile-menu");
    const mobileLinks = document.querySelectorAll(".mobile-link");

    function openMenu() {
      if (!mobileMenu) return;
      mobileMenu.classList.remove("opacity-0", "pointer-events-none");
      mobileMenu.classList.add("opacity-100", "pointer-events-auto");
      document.body.style.overflow = "hidden";
    }

    function closeMenu() {
      if (!mobileMenu) return;
      mobileMenu.classList.remove("opacity-100", "pointer-events-auto");
      mobileMenu.classList.add("opacity-0", "pointer-events-none");
      document.body.style.overflow = "auto";
    }

    if (btnOpen) btnOpen.addEventListener("click", openMenu);
    if (btnClose) btnClose.addEventListener("click", closeMenu);
    mobileLinks.forEach((link) => link.addEventListener("click", closeMenu));

    // 2. Modo Oscuro
    const themeToggle = document.getElementById("theme-toggle");
    const handleToggleClick = () => {
      const element = document.documentElement;
      element.classList.toggle("dark");
      const isDark = element.classList.contains("dark");
      localStorage.setItem("theme", isDark ? "dark" : "light");
    };
    if (themeToggle) themeToggle.onclick = handleToggleClick;
  });
</script>
