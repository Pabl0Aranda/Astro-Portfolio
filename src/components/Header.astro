<header
  class="w-full border-b border-white/10 sticky top-0 bg-black/80 backdrop-blur-md z-50"
>
  <div
    class="max-w-5xl mx-auto px-6 py-4 flex justify-between items-center relative"
  >
    <a
      href="/"
      class="text-xl font-bold tracking-tighter text-white hover:text-albero transition-colors duration-300 relative z-50"
    >
      Pablo<span class="text-albero">.</span>
    </a>

    <nav class="hidden lg:block">
      <ul class="flex gap-5 text-sm font-medium">
        <li>
          <a href="/#" class="hover:text-albero transition-colors duration-300"
            >Home</a>
        </li>
        <li>
          <a
            href="/#formacion"
            class="hover:text-albero transition-colors duration-300"
            >Formación</a>
        </li>
        <li>
          <a
            href="/#habilidades"
            class="hover:text-albero transition-colors duration-300"
            >Habilidades</a>
        </li>
        <li>
          <a
            href="/#proyectos"
            class="hover:text-albero transition-colors duration-300"
            >Proyectos</a>
        </li>
        <li>
          <a
            href="/#experiencia"
            class="hover:text-albero transition-colors duration-300"
            >Experiencia</a>
        </li>
        <li>
          <a
            href="/#contacto"
            class="hover:text-albero transition-colors duration-300"
            >Contacto</a>
        </li>
        <li>
          <a href="/blog" class="text-albero transition-colors duration-300"
            >Blog</a>
        </li>
      </ul>
    </nav>

    <button
      id="menu-toggle"
      class="lg:hidden text-white focus:outline-none relative z-50 p-2"
      aria-label="Abrir menú"
    >
      <svg
        id="menu-icon"
        class="w-6 h-6 transition-transform duration-300"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </div>

  <div
    id="mobile-menu"
    class="fixed inset-0 bg-black flex flex-col items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300 z-40 lg:hidden"
  >
    <nav>
      <ul class="flex flex-col gap-6 text-center text-2xl font-semibold">
        <li>
          <a
            href="/#"
            class="mobile-link hover:text-albero transition-colors duration-300"
            >Home</a>
        </li>
        <li>
          <a
            href="/#formacion"
            class="mobile-link hover:text-albero transition-colors duration-300"
            >Formación</a>
        </li>
        <li>
          <a
            href="/#habilidades"
            class="mobile-link hover:text-albero transition-colors duration-300"
            >Habilidades</a>
        </li>
        <li>
          <a
            href="/#proyectos"
            class="mobile-link hover:text-albero transition-colors duration-300"
            >Proyectos</a>
        </li>
        <li>
          <a
            href="/#experiencia"
            class="mobile-link hover:text-albero transition-colors duration-300"
            >Experiencia</a>
        </li>
        <li>
          <a
            href="/#contacto"
            class="mobile-link hover:text-albero transition-colors duration-300"
            >Contacto</a>
        </li>
        <li>
          <a href="/blog" class="mobile-link text-albero mt-2 block">Blog</a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<script>
  // Obtenemos los elementos
  const menuToggle = document.getElementById("menu-toggle");
  const mobileMenu = document.getElementById("mobile-menu");
  const menuIcon = document.getElementById("menu-icon");
  const mobileLinks = document.querySelectorAll(".mobile-link");

  let isMenuOpen = false;

  function toggleMenu() {
    // COMPROBACIÓN DE SEGURIDAD:
    // Si mobileMenu o menuIcon no existen, detenemos la función aquí mismo.
    // Esto elimina el error 'possibly null' de tu editor.
    if (!mobileMenu || !menuIcon) return;

    isMenuOpen = !isMenuOpen;

    if (isMenuOpen) {
      mobileMenu.classList.remove("opacity-0", "pointer-events-none");
      mobileMenu.classList.add("opacity-100", "pointer-events-auto");

      // Icono X
      menuIcon.innerHTML =
        '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>';
      menuIcon.classList.add("rotate-90");

      document.body.style.overflow = "hidden";
    } else {
      mobileMenu.classList.remove("opacity-100", "pointer-events-auto");
      mobileMenu.classList.add("opacity-0", "pointer-events-none");

      // Icono Hamburguesa
      menuIcon.innerHTML =
        '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>';
      menuIcon.classList.remove("rotate-90");

      document.body.style.overflow = "auto";
    }
  }

  // Comprobamos que el botón existe antes de añadirle el evento
  if (menuToggle) {
    menuToggle.addEventListener("click", toggleMenu);
  }

  // querySelectorAll devuelve una lista (vacía si no hay nada), por lo que forEach es siempre seguro
  mobileLinks.forEach((link) => {
    link.addEventListener("click", () => {
      if (isMenuOpen) toggleMenu();
    });
  });
</script>
